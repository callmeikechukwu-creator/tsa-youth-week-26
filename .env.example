PORT=3000
NODE_ENV=development
SESSION_SECRET=generate-a-random-64-char-string-here
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=change-this-to-a-strong-password

# ── MongoDB ──────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# SITE_URL is optional and no longer used at runtime.
# The app derives siteUrl dynamically from req.protocol + req.get('host').
# Kept here only for reference / legacy tooling.
# SITE_URL=https://your-deployed-domain.com

# ── Google Analytics (public tracking) ──────────────────────────
# The GA4 Measurement ID used in the frontend tracking snippet
GA_TRACKING_ID=G-XXXXXXXXXX

# ── Google Analytics Data API (admin dashboard) ──────────────────
# Your GA4 Property ID — found at: Analytics > Admin > Property Settings
# Format: numeric only, e.g. 123456789  (NOT "properties/123456789")
GA_PROPERTY_ID=

# Service account credentials — choose ONE of the three options below:

# OPTION A (recommended for hosted deployments):
# Paste the full contents of your service account JSON key as a single-line string
GA_SERVICE_ACCOUNT_JSON=

# OPTION B (alternative for hosted deployments):
# Base64-encode your service account JSON:  base64 -w0 your-key.json
GA_SERVICE_ACCOUNT_B64=

# OPTION C (local development):
# Point to the service account JSON file on disk
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
