</div>

<!-- Download Modal -->
<div class="dl-overlay" id="dlOverlay">
  <div class="dl-modal">
    <div class="dl-modal-icon" id="dlIcon">
      <div class="dl-spinner" id="dlSpinner"></div>
      <svg id="dlSuccessIcon" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"/></svg>
      <svg id="dlErrorIcon" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/><path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/></svg>
    </div>
    <div class="dl-modal-title" id="dlTitle">Generating PDF</div>
    <div class="dl-modal-msg" id="dlMsg">Preparing your document...</div>
    <div class="dl-modal-filename" id="dlFilename"></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.4/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
/* ── Clock ── */
function tick(){const e=new Date;document.getElementById('admClock').textContent=e.toLocaleTimeString('en-NG',{hour:'2-digit',minute:'2-digit'})+' · '+e.toLocaleDateString('en-NG',{day:'2-digit',month:'short',year:'numeric'})}tick();setInterval(tick,1000);

/* ── Sidebar toggle ── */
const sidebar=document.getElementById('admSidebar'),overlay=document.getElementById('admOverlay'),hamburger=document.getElementById('admHamburger');
hamburger.addEventListener('click',()=>{sidebar.classList.toggle('open');overlay.classList.toggle('open');document.body.style.overflow=sidebar.classList.contains('open')?'hidden':''});
overlay.addEventListener('click',()=>{sidebar.classList.remove('open');overlay.classList.remove('open');document.body.style.overflow=''});

/* ── Delete modal ── */
const delOverlay=document.getElementById('delOverlay'),delModalId=document.getElementById('delModalId'),delCancel=document.getElementById('delCancel'),delConfirm=document.getElementById('delConfirm');
let pendingDelete=null;
function confirmDelete(e){pendingDelete={id:e.dataset.id,type:e.dataset.type};delModalId.textContent=e.dataset.id;delConfirm.disabled=false;delConfirm.textContent='Delete';delOverlay.classList.add('open')}
function closeDeleteModal(){delOverlay.classList.remove('open');pendingDelete=null}
delCancel.addEventListener('click',closeDeleteModal);
delOverlay.addEventListener('click',e=>{if(e.target===delOverlay)closeDeleteModal()});
delConfirm.addEventListener('click',function(){
  if(!pendingDelete)return;
  const{id,type}=pendingDelete;
  delConfirm.disabled=true;delConfirm.textContent='Deleting…';
  fetch('/admin/'+type+'/'+id,{method:'DELETE',headers:{Accept:'application/json','X-CSRF-Token':document.querySelector('meta[name="csrf-token"]').content}})
    .then(r=>r.json()).then(res=>{
      if(res.success){document.querySelectorAll('[data-id="'+id+'"]').forEach(el=>{if(el.tagName==='TR'||el.classList.contains('adm-mobile-card')){el.style.opacity=0;setTimeout(()=>el.remove(),300)}});closeDeleteModal();setTimeout(()=>location.reload(),400)}
      else{delConfirm.textContent='Failed';setTimeout(()=>{delConfirm.textContent='Delete';delConfirm.disabled=false},1500)}
    }).catch(()=>{delConfirm.textContent='Error';setTimeout(()=>{delConfirm.textContent='Delete';delConfirm.disabled=false},1500)});
});

/* ── Download modal helpers ── */
var dlOverlay=document.getElementById('dlOverlay'),dlIcon=document.getElementById('dlIcon'),dlSpinner=document.getElementById('dlSpinner'),dlSuccessIc=document.getElementById('dlSuccessIcon'),dlErrorIc=document.getElementById('dlErrorIcon'),dlTitle=document.getElementById('dlTitle'),dlMsg=document.getElementById('dlMsg'),dlFilename=document.getElementById('dlFilename');
var MIN_MS=1500;
function fileStamp(){var d=new Date();return d.getFullYear()+String(d.getMonth()+1).padStart(2,'0')+String(d.getDate()).padStart(2,'0')+'-'+String(d.getHours()).padStart(2,'0')+String(d.getMinutes()).padStart(2,'0')+String(d.getSeconds()).padStart(2,'0')}
function fmtDate(iso){var d=new Date(iso);return d.toLocaleDateString('en-NG',{day:'2-digit',month:'short',year:'numeric'})+' '+d.toLocaleTimeString('en-NG',{hour:'2-digit',minute:'2-digit'})}
function showDl(f,l){dlIcon.className='dl-modal-icon';dlSpinner.style.display='';dlSuccessIc.style.display='none';dlErrorIc.style.display='none';dlTitle.textContent='Preparing '+l;dlMsg.textContent='Building document…';dlFilename.textContent=f;dlOverlay.classList.add('open')}
function showOk(f,l){dlIcon.className='dl-modal-icon success';dlSpinner.style.display='none';dlSuccessIc.style.display='';dlTitle.textContent='Download Complete';dlMsg.textContent='Your '+l+' file has been saved.';dlFilename.textContent=f;setTimeout(()=>dlOverlay.classList.remove('open'),2000)}
function showErr(m){dlIcon.className='dl-modal-icon error';dlSpinner.style.display='none';dlErrorIc.style.display='';dlTitle.textContent='Download Failed';dlMsg.textContent=m||'Something went wrong.';dlFilename.textContent='';setTimeout(()=>dlOverlay.classList.remove('open'),2500)}
function delayThen(start,fn){setTimeout(fn,Math.max(0,MIN_MS-(Date.now()-start)))}
function triggerBlob(blob,name){var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name;document.body.appendChild(a);a.click();document.body.removeChild(a);setTimeout(()=>URL.revokeObjectURL(a.href),1000)}

/* ── Load brand fonts for PDF ── */
var _bebasB64=null,_jakartaRegB64=null,_jakartaBoldB64=null,_whiteLogo=null,_logoAspect=1;
function loadFontB64(url){return fetch(url).then(r=>r.arrayBuffer()).then(buf=>{var b=new Uint8Array(buf),s='';for(var i=0;i<b.length;i++)s+=String.fromCharCode(b[i]);return btoa(s)})}
var _fontsReady=Promise.all([
  loadFontB64('/fonts/BebasNeue-Regular.ttf').then(b=>{_bebasB64=b}),
  loadFontB64('/fonts/PlusJakartaSans-Regular.ttf').then(b=>{_jakartaRegB64=b}),
  loadFontB64('/fonts/PlusJakartaSans-Bold.ttf').then(b=>{_jakartaBoldB64=b})
]).catch(()=>{});
var _logoReady=new Promise(resolve=>{var img=new Image();img.crossOrigin='anonymous';img.onload=function(){_logoAspect=img.width/img.height;var c=document.createElement('canvas');c.width=img.width;c.height=img.height;var ctx=c.getContext('2d');ctx.drawImage(img,0,0);var d=ctx.getImageData(0,0,c.width,c.height);for(var i=0;i<d.data.length;i+=4){d.data[i]=255;d.data[i+1]=255;d.data[i+2]=255}ctx.putImageData(d,0,0);_whiteLogo=c.toDataURL('image/png');resolve()};img.onerror=resolve;img.src='/images/tsa-logo.png'});
function regFonts(doc){if(_bebasB64){doc.addFileToVFS('BebasNeue.ttf',_bebasB64);doc.addFont('BebasNeue.ttf','BebasNeue','normal')}if(_jakartaRegB64){doc.addFileToVFS('PlusJakartaSans-Reg.ttf',_jakartaRegB64);doc.addFont('PlusJakartaSans-Reg.ttf','PlusJakartaSans','normal')}if(_jakartaBoldB64){doc.addFileToVFS('PlusJakartaSans-Bold.ttf',_jakartaBoldB64);doc.addFont('PlusJakartaSans-Bold.ttf','PlusJakartaSans','bold')}}
var TF=()=>_bebasB64?'BebasNeue':'helvetica';
var BF=()=>_jakartaRegB64?'PlusJakartaSans':'helvetica';

function drawPdfHeader(doc,title,count,label,generated){
  var pw=doc.internal.pageSize.getWidth(),steps=80,hH=28;
  for(var i=0;i<steps;i++){var r=Math.round(10+i/steps*194);doc.setFillColor(r,Math.max(0,10-i/steps*10),Math.max(0,40-i/steps*40));doc.rect(i*pw/steps,0,pw/steps+.5,hH,'F')}
  if(_whiteLogo){var lh=18,lw=lh*_logoAspect;doc.addImage(_whiteLogo,'PNG',10,5,lw,lh)}
  doc.setFont(TF(),'normal');doc.setFontSize(18);doc.setTextColor(255,255,255);doc.text(title,34,13);
  doc.setFont(BF(),'normal');doc.setFontSize(9);doc.setTextColor(255,200,200);doc.text('IBCC Youth Week 26',34,19);
  doc.setFont(TF(),'normal');doc.setFontSize(24);doc.setTextColor(255,255,255);doc.text(String(count),pw-10,14,{align:'right'});
  doc.setFont(BF(),'normal');doc.setFontSize(8);doc.setTextColor(255,200,200);doc.text(label,pw-10,20,{align:'right'});
  doc.setFillColor(204,0,0);doc.rect(0,hH,pw,2,'F');
  doc.setFillColor(245,245,250);doc.rect(0,hH+2,pw,10,'F');
  doc.setFont(BF(),'normal');doc.setFontSize(8);doc.setTextColor(100,100,130);
  doc.text(count+' '+label,10,hH+8.5);doc.text('Generated: '+generated,pw-10,hH+8.5,{align:'right'});
  return hH+16;
}

function buildPdf(title,label,head,body){
  var jsPDF=window.jspdf.jsPDF,doc=new jsPDF({orientation:'landscape',unit:'mm',format:'a4'});
  regFonts(doc);
  var pw=doc.internal.pageSize.getWidth(),generated=fmtDate(new Date().toISOString());
  var startY=drawPdfHeader(doc,title,body.length,label,generated);
  doc.autoTable({head:[head],body:body,startY,theme:'grid',
    styles:{font:BF(),fontSize:8.5,cellPadding:3,textColor:[30,30,50],lineColor:[220,220,230],lineWidth:.2},
    headStyles:{fillColor:[30,30,55],textColor:[255,255,255],fontStyle:'bold',fontSize:7.5,font:BF()},
    alternateRowStyles:{fillColor:[248,248,252]},margin:{left:8,right:8},
    didDrawPage:function(d){
      if(d.pageNumber>1)drawPdfHeader(doc,title,body.length,label,generated);
      var ph=doc.internal.pageSize.getHeight();doc.setFont(BF(),'normal');doc.setFontSize(7);doc.setTextColor(150,150,170);
      doc.text('IBCC Youth Week 26 — '+title,8,ph-5);doc.text('Page '+d.pageNumber,pw-8,ph-5,{align:'right'});
    }
  });
  return doc.output('blob');
}

/* ── Data for client-side PDF ── */
var __registrations=JSON.parse('<%- JSON.stringify(registrations).replace(/\\/g,"\\\\\\\\").replace(/\'/g,"\\\\u0027").replace(/</g,"\\\\u003c").replace(/>/g,"\\\\u003e") %>');
var __contacts=JSON.parse('<%- JSON.stringify(contacts).replace(/\\/g,"\\\\\\\\").replace(/\'/g,"\\\\u0027").replace(/</g,"\\\\u003c").replace(/>/g,"\\\\u003e") %>');

/* ── Log download to server ── */
function logDl(type,dataset,filename){fetch('/admin/api/log-download',{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json','X-CSRF-Token':document.querySelector('meta[name="csrf-token"]').content},body:JSON.stringify({type:type,dataset:dataset,filename:filename})}).catch(()=>{})}

/* ── PDF links ── */
document.querySelectorAll('.pdf-download-link').forEach(link=>{
  link.addEventListener('click',e=>{
    e.preventDefault();if(link.classList.contains('disabled'))return;
    var isReg=link.getAttribute('href').includes('registrations');
    var stamp=fileStamp(),f=(isReg?'yw26-registrations-':'yw26-contacts-')+stamp+'.pdf',start=Date.now();
    showDl(f,'PDF');
    Promise.all([_logoReady,_fontsReady]).then(()=>{
      try{
        var blob=isReg
          ?buildPdf('REGISTRATIONS','registrations',['ID','Name','Email','Age','Church / Corps','Role','Heard Via','Date'],__registrations.map(r=>[r.id,r.name,r.email,r.age,r.church||'—',r.role,r.heard||'—',fmtDate(r.createdAt)]))
          :buildPdf('MESSAGES','messages',['ID','Name','Email','Phone','Subject','Message','Date'],__contacts.map(c=>[c.id,c.name,c.email,c.phone||'—',c.subject||'general',c.message,fmtDate(c.createdAt)]));
        delayThen(start,()=>{triggerBlob(blob,f);showOk(f,'PDF');logDl('PDF',isReg?'registrations':'contacts',f)});
      }catch(err){delayThen(start,()=>showErr(err.message))}
    });
  });
});

/* ── CSV/JSON links ── */
document.querySelectorAll('.file-download-link').forEach(link=>{
  link.addEventListener('click',e=>{
    e.preventDefault();if(link.classList.contains('disabled'))return;
    var url=link.getAttribute('href'),isJSON=url.includes('/json'),ext=isJSON?'.json':'.csv',label=isJSON?'JSON':'CSV';
    var isReg=url.includes('registrations'),stamp=fileStamp(),f=(isReg?'yw26-registrations-':'yw26-contacts-')+stamp+ext,start=Date.now();
    showDl(f,label);
    fetch(url,{credentials:'same-origin'}).then(r=>{if(!r.ok)throw new Error('Server error');return r.blob()})
      .then(blob=>delayThen(start,()=>{triggerBlob(blob,f);showOk(f,label)}))
      .catch(err=>delayThen(start,()=>showErr(err.message)));
  });
});

/* ── Analytics ── */
var elLoading=document.getElementById('gaLoading'),elError=document.getElementById('gaError'),elErrorMsg=document.getElementById('gaErrorMsg'),elNotCfg=document.getElementById('gaNotConfigured'),elNotCfgMsg=document.getElementById('gaNotConfiguredMsg'),elData=document.getElementById('gaData');
var elKpis=document.getElementById('gaKpis'),elPages=document.getElementById('gaPages'),elCountries=document.getElementById('gaCountries'),elDeviceLeg=document.getElementById('gaDeviceLegend');
var elRTPill=document.getElementById('gaRealtimePill'),elRTNum=document.getElementById('gaRealtimeNum'),elNavBadge=document.getElementById('analyticsRealtimeBadge');
var trendChart=null,sourceChart=null,deviceChart=null;
var COLORS=['#cc0000','#0055cc','#ffd700','#00b87a','#9955ff','#ff7722','#22ccdd','#ff4488'];
function fmtNum(n){return n>=1e6?(n/1e6).toFixed(1)+'M':n>=1e3?(n/1e3).toFixed(1)+'k':String(n)}
function fmtDur(s){return Math.floor(s/60)+'m '+s%60+'s'}
function fmtTrendDate(d){var y=d.slice(0,4),m=d.slice(4,6),dd=d.slice(6,8);return new Date(y+'-'+m+'-'+dd).toLocaleDateString('en-NG',{month:'short',day:'numeric'})}
function showGaState(s){elLoading.style.display=s==='loading'?'':'none';elError.style.display=s==='error'?'':'none';elNotCfg.style.display=s==='uncfg'?'':'none';elData.style.display=s==='data'?'':'none'}
function kpiCard(label,value,sub,color){return'<div style="background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:12px;padding:14px 16px;"><div style="font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:6px;">'+label+'</div><div style="font-size:26px;font-weight:800;color:'+color+';line-height:1;">'+value+'</div>'+(sub?'<div style="font-size:11px;color:var(--muted);margin-top:4px;">'+sub+'</div>':'')+'</div>'}
function barRow(label,value,maxVal,color){var pct=maxVal?Math.round(value/maxVal*100):0;return'<div style="margin-bottom:10px;"><div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;"><span style="color:var(--fg);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:70%;">'+label+'</span><span style="color:var(--muted);">'+fmtNum(value)+'</span></div><div style="height:5px;background:rgba(255,255,255,.06);border-radius:99px;overflow:hidden;"><div style="height:100%;width:'+pct+'%;background:'+color+';border-radius:99px;"></div></div></div>'}
function renderGa(d){
  var ov=d.overview;
  elKpis.innerHTML=kpiCard('Sessions',fmtNum(ov.sessions),'30-day total','#cc0000')+kpiCard('Users',fmtNum(ov.users),'30-day unique','#0055cc')+kpiCard('Page Views',fmtNum(ov.pageviews),'30-day total','#ffd700')+kpiCard('Bounce Rate',ov.bounceRate+'%','lower is better',ov.bounceRate>70?'#ff5555':'#00b87a')+kpiCard('Avg. Duration',fmtDur(ov.avgDuration),'per session','#9955ff');
  if(trendChart)trendChart.destroy();
  trendChart=new Chart(document.getElementById('gaTrendChart'),{type:'bar',data:{labels:d.trend.map(r=>fmtTrendDate(r.date)),datasets:[{label:'Sessions',data:d.trend.map(r=>r.sessions),backgroundColor:'rgba(204,0,0,.7)',borderRadius:4,order:2},{label:'Users',data:d.trend.map(r=>r.users),type:'line',borderColor:'#ffd700',backgroundColor:'rgba(255,215,0,.08)',pointRadius:3,pointBackgroundColor:'#ffd700',tension:.4,fill:true,order:1}]},options:{responsive:true,interaction:{mode:'index',intersect:false},plugins:{legend:{labels:{color:'rgba(255,255,255,.6)',font:{size:11},boxWidth:10}}},scales:{x:{ticks:{color:'rgba(255,255,255,.4)',font:{size:10}},grid:{color:'rgba(255,255,255,.04)'}},y:{ticks:{color:'rgba(255,255,255,.4)',font:{size:10}},grid:{color:'rgba(255,255,255,.06)'}}}}}); 
  if(sourceChart)sourceChart.destroy();
  var sl=d.sources.map(r=>r.channel),sv=d.sources.map(r=>r.sessions);
  sourceChart=new Chart(document.getElementById('gaSourceChart'),{type:'bar',data:{labels:sl,datasets:[{data:sv,backgroundColor:sl.map((_,i)=>COLORS[i%COLORS.length]),borderRadius:5}]},options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false}},scales:{x:{ticks:{color:'rgba(255,255,255,.4)',font:{size:10}},grid:{color:'rgba(255,255,255,.06)'}},y:{ticks:{color:'rgba(255,255,255,.6)',font:{size:11}},grid:{display:false}}}}});
  if(deviceChart)deviceChart.destroy();
  var dl=d.devices.map(r=>r.device),dv=d.devices.map(r=>r.sessions);
  deviceChart=new Chart(document.getElementById('gaDeviceChart'),{type:'doughnut',data:{labels:dl,datasets:[{data:dv,backgroundColor:COLORS.slice(0,dl.length),borderWidth:0,hoverOffset:4}]},options:{responsive:true,cutout:'68%',plugins:{legend:{display:false}}}});
  elDeviceLeg.innerHTML=d.devices.map((r,i)=>'<div style="display:flex;align-items:center;justify-content:space-between;font-size:12px;margin-bottom:6px;"><span style="display:flex;align-items:center;gap:6px;"><span style="width:10px;height:10px;border-radius:50%;background:'+COLORS[i%COLORS.length]+';flex-shrink:0;"></span><span style="text-transform:capitalize;color:var(--fg);">'+r.device+'</span></span><span style="color:var(--muted);">'+r.pct+'%</span></div>').join('');
  var mp=d.pages.length?d.pages[0].views:1;elPages.innerHTML=d.pages.map(p=>barRow(p.path,p.views,mp,'#cc0000')).join('');
  var mc=d.countries.length?d.countries[0].sessions:1;elCountries.innerHTML=d.countries.map(c=>barRow(c.country,c.sessions,mc,'#0055cc')).join('');
  showGaState('data');
}
function loadAnalytics(){
  showGaState('loading');document.getElementById('gaRefreshBtn').disabled=true;
  fetch('/admin/analytics-data',{credentials:'same-origin'}).then(r=>r.json()).then(res=>{
    document.getElementById('gaRefreshBtn').disabled=false;
    if(!res.ok&&res.unconfigured){elNotCfgMsg.innerHTML=res.error||'Configure GA_PROPERTY_ID in .env';showGaState('uncfg');return}
    if(!res.ok){elErrorMsg.textContent=res.error||'Unknown error';showGaState('error');return}
    renderGa(res.data);
  }).catch(err=>{document.getElementById('gaRefreshBtn').disabled=false;elErrorMsg.textContent=err.message;showGaState('error')});
}
function pollRealtime(){fetch('/admin/analytics-realtime',{credentials:'same-origin'}).then(r=>r.json()).then(res=>{if(res.ok&&res.activeUsers!==null){var n=res.activeUsers;elRTNum.textContent=n;elRTPill.style.display='';if(elNavBadge){elNavBadge.style.display='';elNavBadge.textContent=n}}}).catch(()=>{})}
document.getElementById('gaRefreshBtn').addEventListener('click',loadAnalytics);
loadAnalytics();pollRealtime();setInterval(pollRealtime,30000);
</script>

