<%
const ap = locals.activePage || '';
function isActive(p) { return ap === p ? ' active' : ''; }
const _regCount = locals.regCount !== undefined ? locals.regCount : '';
const _contactCount = locals.contactCount !== undefined ? locals.contactCount : '';
%>
<aside class="adm-sidebar" id="admSidebar">
  <div class="adm-sidebar-inner">
    <div class="adm-brand">
      <img src="/images/tsa-logo.png" alt="TSA">
      <div class="adm-brand-text">
        <strong>IBCC ADMIN</strong>
        <span>Youth Week 26</span>
      </div>
    </div>

    <div class="adm-nav-section">Navigation</div>

    <a href="/admin" class="adm-link<%= isActive('dashboard') %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M4 .5a.5.5 0 0 0-1 0V1H2a2 2 0 0 0-2 2v1h16V3a2 2 0 0 0-2-2h-1V.5a.5.5 0 0 0-1 0V1H4zM16 14V5H0v9a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2m-5.5-8h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1 0-1m0 2h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1 0-1m0 2h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1 0-1m-2-4h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1 0-1m0 2h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1 0-1m0 2h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1 0-1m-2-4h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1 0-1m0 2h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1 0-1m0 2h1a.5.5 0 0 1 0 1h-1a.5.5 0 0 1 0-1"/></svg>
      Dashboard
    </a>

    <div class="adm-nav-section" style="margin-top:8px;">Records</div>

    <a href="/admin/registrations" class="adm-link<%= isActive('registrations') %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.24 2.24 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.3 6.3 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1zM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5"/></svg>
      Registrations
      <% if (_regCount !== '') { %><span class="adm-link-badge"><%= _regCount %></span><% } %>
    </a>

    <a href="/admin/contacts" class="adm-link<%= isActive('contacts') %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1zm13 2.383-4.708 2.825L15 11.105zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741M1 11.105l4.708-2.897L1 5.383z"/></svg>
      Messages
      <% if (_contactCount !== '') { %><span class="adm-link-badge" style="background:rgba(0,100,255,.2);color:#6699ff;"><%= _contactCount %></span><% } %>
    </a>

    <div class="adm-nav-section" style="margin-top:8px;">Analytics</div>

    <a href="/admin/analytics" class="adm-link<%= isActive('analytics') %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M0 0h1v15h15v1H0zm14.817 3.113a.5.5 0 0 1 .07.704l-4.5 5.5a.5.5 0 0 1-.74.037L7.06 6.767l-3.656 5.027a.5.5 0 0 1-.808-.588l4-5.5a.5.5 0 0 1 .758-.06l2.609 2.61 4.15-5.073a.5.5 0 0 1 .704-.07"/></svg>
      Analytics
      <span class="adm-link-badge" id="analyticsRealtimeBadge" style="display:none;background:rgba(0,200,120,.2);color:#00c878;">0</span>
    </a>

    <div class="adm-nav-section" style="margin-top:8px;">Profile</div>

    <a href="/admin/profile" class="adm-link<%= isActive('profile') %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"/></svg>
      Profile
    </a>

    <a href="/admin/accounts" class="adm-link<%= isActive('accounts') %>">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M11 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0M8 7a2 2 0 1 0 0-4 2 2 0 0 0 0 4m.256 7a4.5 4.5 0 0 1-.229-1.004H3c.001-.246.154-.986.832-1.664C4.484 10.68 5.711 10 8 10q.39 0 .74.025c.226-.341.496-.65.804-.918Q8.844 9.002 8 9c-5 0-6 3-6 4s1 1 1 1zm3.63-4.54c.18-.613 1.048-.613 1.229 0l.043.148a.64.64 0 0 0 .921.382l.136-.074c.561-.306 1.175.308.87.869l-.075.136a.64.64 0 0 0 .382.92l.149.045c.612.18.612 1.048 0 1.229l-.15.043a.64.64 0 0 0-.38.921l.074.136c.305.561-.309 1.175-.87.87l-.136-.075a.64.64 0 0 0-.92.382l-.045.149c-.18.612-1.048.612-1.229 0l-.043-.15a.64.64 0 0 0-.921-.38l-.136.074c-.561.305-1.175-.309-.87-.87l.075-.136a.64.64 0 0 0-.382-.92l-.148-.045c-.613-.18-.613-1.048 0-1.229l.148-.043a.64.64 0 0 0 .382-.921l-.074-.136c-.306-.561.308-1.175.869-.87l.136.075a.64.64 0 0 0 .92-.382zM14 12.5a1.5 1.5 0 1 0-3 0 1.5 1.5 0 0 0 3 0"/></svg>
      Accounts
    </a>

    <div class="adm-nav-section" style="margin-top:8px;">Website</div>

    <a href="/" target="_blank" class="adm-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M8.636 3.5a.5.5 0 0 0-.5-.5H1.5A1.5 1.5 0 0 0 0 4.5v10A1.5 1.5 0 0 0 1.5 16h10a1.5 1.5 0 0 0 1.5-1.5V7.864a.5.5 0 0 0-1 0V14.5a.5.5 0 0 1-.5.5h-10a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h6.636a.5.5 0 0 0 .5-.5"/><path fill-rule="evenodd" d="M16 .5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h3.793L6.146 9.146a.5.5 0 1 0 .708.708L15 1.707V5.5a.5.5 0 0 0 1 0z"/></svg>
      View Website
    </a>
  </div>

  <div class="adm-sidebar-footer">
    <button type="button" class="adm-logout" id="signOutBtn">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z"/><path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/></svg>
      Sign Out
    </button>
  </div>
</aside>

<!-- Sign-out confirmation modal -->
<div class="so-overlay" id="signOutOverlay" style="display:none;position:fixed;inset:0;z-index:10000;justify-content:center;align-items:center;background:rgba(0,0,0,.6);backdrop-filter:blur(4px);">
  <div class="so-modal">
    <div class="so-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z"/><path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/></svg>
    </div>
    <div class="so-title">Sign Out</div>
    <div class="so-msg">Are you sure you want to end your session?</div>
    <div class="so-actions">
      <button type="button" class="so-btn-cancel" id="soCancel">Cancel</button>
      <form action="/admin/logout" method="POST" id="signOutForm" style="margin:0;padding:0;display:contents;">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="so-btn-confirm" id="signOutConfirm">
          <span id="soLabel">Sign Out</span>
          <span id="soLoading" style="display:none;"><span class="so-spinner"></span> Signing out</span>
        </button>
      </form>
    </div>
  </div>
</div>
<script>
(function(){
  var ov=document.getElementById('signOutOverlay');
  document.getElementById('signOutBtn').onclick=function(){ov.style.display='flex';};
  document.getElementById('soCancel').onclick=function(){ov.style.display='none';};
  ov.addEventListener('click',function(e){if(e.target===ov)ov.style.display='none';});
  document.getElementById('signOutForm').addEventListener('submit',function(){
    document.getElementById('signOutConfirm').disabled=true;
    document.getElementById('soLabel').style.display='none';
    document.getElementById('soLoading').style.display='inline-flex';
    document.getElementById('soCancel').disabled=true;
  });
})();
</script>
