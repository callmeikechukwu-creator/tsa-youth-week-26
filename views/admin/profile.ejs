<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title>Profile — Admin · IBCC Youth Week 26</title>
  <link rel="icon" type="image/png" href="/images/tsa-logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.min.css">
  <style>
    .prof-hero {
      background: linear-gradient(135deg, rgba(204,0,0,.15) 0%, rgba(0,51,160,.1) 100%);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 40px 36px;
      margin-bottom: 28px;
      position: relative;
      overflow: hidden;
    }
    .prof-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, var(--red), #4488ff);
    }
    .prof-hero-inner {
      display: flex;
      align-items: center;
      gap: 24px;
    }
    .prof-avatar {
      width: 96px; height: 96px;
      border-radius: 50%;
      background: linear-gradient(135deg, #cc0000, #001a8c);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 42px;
      font-weight: 900;
      color: #fff;
      flex-shrink: 0;
      box-shadow: 0 4px 24px rgba(204,0,0,.25);
    }
    .prof-info { flex: 1; min-width: 0; }
    .prof-email {
      font-size: 24px;
      font-weight: 800;
      color: var(--text);
      word-break: break-all;
    }
    .prof-role {
      font-size: 14px;
      color: var(--muted);
      margin-top: 6px;
    }
    .prof-badges {
      display: flex;
      gap: 8px;
      margin-top: 10px;
      flex-wrap: wrap;
    }
    .prof-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 24px;
      margin-bottom: 28px;
    }
    .prof-section {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--r-lg);
      padding: 32px;
    }
    .prof-section-title {
      font-family: var(--font-d);
      font-size: 22px;
      letter-spacing: 1.5px;
      margin-bottom: 22px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .prof-section-title svg { opacity: .5; flex-shrink: 0; }
    .prof-field {
      margin-bottom: 16px;
    }
    .prof-field label {
      display: block;
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--muted);
      margin-bottom: 10px;
    }
    .prof-input-wrap { position: relative; }
    .prof-input {
      width: 100%;
      background: rgba(255,255,255,.06);
      border: 1px solid rgba(255,255,255,.12);
      color: var(--text);
      padding: 14px 44px 14px 16px;
      border-radius: 8px;
      font-size: 15px;
      font-family: inherit;
      outline: none;
      box-sizing: border-box;
      transition: border-color .2s, box-shadow .2s;
    }
    .prof-input:focus {
      border-color: var(--red);
      box-shadow: 0 0 0 3px rgba(204,0,0,.2);
    }
    .pw-toggle {
      position: absolute;
      right: 12px;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      cursor: pointer;
      color: var(--muted);
      padding: 0;
      display: flex;
      transition: color .15s;
    }
    .pw-toggle:hover { color: var(--text); }
    .strength-bar {
      height: 4px;
      background: rgba(255,255,255,.08);
      border-radius: 99px;
      overflow: hidden;
      margin-top: 8px;
    }
    .strength-fill {
      height: 100%;
      width: 0%;
      border-radius: 99px;
      transition: width .3s, background .3s;
    }
    .strength-label {
      font-size: 11px;
      color: var(--muted);
      margin-top: 4px;
    }
    .prof-gen-box {
      display: flex;
      gap: 14px;
      align-items: center;
      padding: 16px 18px;
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 8px;
      margin-bottom: 18px;
    }
    .prof-gen-info { flex: 1; }
    .prof-gen-title {
      font-size: 14px;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 2px;
    }
    .prof-gen-sub {
      font-size: 13px;
      color: var(--muted);
    }
    .prof-gen-btn {
      background: rgba(255,215,0,.12);
      border: 1px solid rgba(255,215,0,.2);
      color: #ffd700;
      padding: 10px 20px;
      border-radius: 8px;
      font-size: 14px;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      white-space: nowrap;
      transition: all .2s;
    }
    .prof-gen-btn:hover { background: rgba(255,215,0,.2); }
    .prof-pw-result {
      display: none;
      background: rgba(255,215,0,.06);
      border: 1px solid rgba(255,215,0,.15);
      border-radius: 8px;
      padding: 14px 16px;
      margin-bottom: 16px;
    }
    .prof-pw-result-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: #ffd700;
      margin-bottom: 8px;
    }
    .prof-pw-result-row {
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .prof-pw-result-row code {
      font-family: monospace;
      font-size: 15px;
      color: var(--text);
      letter-spacing: 1.5px;
      flex: 1;
      word-break: break-all;
    }
    .prof-btn-sm {
      padding: 8px 14px;
      border-radius: 6px;
      font-size: 12px;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      white-space: nowrap;
      transition: all .15s;
    }
    .prof-btn-use { background: #cc0000; color: #fff; border: none; }
    .prof-btn-use:hover { background: #a30000; }
    .prof-btn-copy { background: rgba(255,255,255,.08); color: var(--text); border: 1px solid rgba(255,255,255,.12); }
    .prof-btn-copy:hover { background: rgba(255,255,255,.14); }
    .prof-submit {
      background: #cc0000;
      color: #fff;
      border: none;
      padding: 14px 32px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 700;
      font-family: inherit;
      cursor: pointer;
      transition: background .2s;
    }
    .prof-submit:hover { background: #a30000; }
    .prof-alert {
      border-radius: 8px;
      padding: 14px 18px;
      margin-bottom: 18px;
      font-size: 14px;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .prof-alert.error {
      background: rgba(204,0,0,.12);
      border: 1px solid rgba(204,0,0,.3);
      color: #ff7777;
    }
    .prof-alert.success {
      background: rgba(0,180,120,.12);
      border: 1px solid rgba(0,180,120,.3);
      color: #55ddaa;
    }
    .cred-card {
      display: flex;
      gap: 18px;
      align-items: center;
      padding: 24px;
      background: rgba(255,255,255,.03);
      border: 1px solid rgba(255,255,255,.07);
      border-radius: 10px;
      transition: border-color .15s;
    }
    .cred-card:hover { border-color: rgba(255,255,255,.14); }
    .cred-icon {
      width: 52px; height: 52px;
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .cred-info { flex: 1; min-width: 0; }
    .cred-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 4px; }
    .cred-desc { font-size: 13px; color: var(--muted); line-height: 1.5; }
    .cred-btn {
      padding: 10px 20px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 700;
      border: none;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: inherit;
      white-space: nowrap;
      transition: all .15s;
    }
    .cred-btn-red { background: var(--red); color: #fff; }
    .cred-btn-red:hover { background: #a30000; }
    .sec-note {
      display: flex;
      gap: 10px;
      align-items: flex-start;
      font-size: 14px;
      color: var(--muted);
      line-height: 1.6;
    }
    .sec-note + .sec-note { margin-top: 12px; }
    .sec-icon { flex-shrink: 0; font-size: 15px; }
    @media (max-width: 480px) {
      .prof-hero { padding: 20px 16px; }
      .prof-avatar { width: 56px; height: 56px; font-size: 24px; }
      .prof-email { font-size: 16px; }
      .prof-role { font-size: 12px; }
      .prof-hero-inner { gap: 16px; }
      .prof-section { padding: 18px; }
      .prof-section-title { font-size: 18px; margin-bottom: 16px; }
      .prof-gen-box { flex-direction: column; align-items: stretch; }
      .prof-gen-btn { text-align: center; }
      .cred-card { flex-direction: column; align-items: stretch; text-align: center; }
      .cred-btn { justify-content: center; width: 100%; }
    }
  </style>
</head>
<body>

<div class="adm-overlay" id="admOverlay"></div>
<div class="adm-layout">

  <% locals.activePage = 'profile'; %>
  <%- include('partials/sidebar') %>

  <main class="adm-main">
    <div class="adm-topbar">
      <div class="adm-topbar-left">
        <button class="adm-hamburger" id="admHamburger" aria-label="Toggle menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/></svg>
        </button>
        <h1>PROFILE</h1>
      </div>
      <div class="adm-topbar-right">
        <span class="adm-time" id="admClock"></span>
      </div>
    </div>

    <div class="adm-content" style="max-width:760px;margin-left:auto;margin-right:auto;">

      <!-- Profile Hero -->
      <div class="prof-hero">
        <div class="prof-hero-inner">
          <div class="prof-avatar"><%= email.charAt(0).toUpperCase() %></div>
          <div class="prof-info">
            <div class="prof-email"><%= email %></div>
            <div class="prof-role">Administrator · IBCC Youth Week 26</div>
            <div class="prof-badges">
              <span class="adm-badge green">Active Session</span>
              <span class="adm-badge red">Admin</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Two-column grid -->
      <div class="prof-grid">

        <!-- Left: Change Password -->
        <div class="prof-section">
          <div class="prof-section-title">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-fill-lock" viewBox="0 0 16 16">
  <path d="M11 5a3 3 0 1 1-6 0 3 3 0 0 1 6 0m-9 8c0 1 1 1 1 1h5v-1a2 2 0 0 1 .01-.2 4.49 4.49 0 0 1 1.534-3.693Q8.844 9.002 8 9c-5 0-6 3-6 4m7 0a1 1 0 0 1 1-1v-1a2 2 0 1 1 4 0v1a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1h-4a1 1 0 0 1-1-1zm3-3a1 1 0 0 0-1 1v1h2v-1a1 1 0 0 0-1-1"/>
</svg>
            Change Password
          </div>

          <% if (error) { %>
            <div class="prof-alert error">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
              <%= error %>
            </div>
          <% } %>
          <% if (success) { %>
            <div class="prof-alert success">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"/></svg>
              <%= success %>
            </div>
          <% } %>

          <form action="/admin/profile/password" method="POST" id="pwForm" autocomplete="off">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="prof-field">
              <label>Current Password</label>
              <div class="prof-input-wrap">
                <input type="password" name="currentPassword" id="currentPassword" class="prof-input" required autocomplete="current-password">
                <button type="button" class="pw-toggle" data-target="currentPassword">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0"/><path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8m8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7"/></svg>
                </button>
              </div>
            </div>

            <div class="prof-field">
              <label>New Password</label>
              <div class="prof-input-wrap">
                <input type="password" name="newPassword" id="newPassword" class="prof-input" required autocomplete="new-password">
                <button type="button" class="pw-toggle" data-target="newPassword">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0"/><path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8m8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7"/></svg>
                </button>
              </div>
              <div class="strength-bar"><div class="strength-fill" id="pwStrengthBar"></div></div>
              <div class="strength-label" id="pwStrengthLabel"></div>
            </div>

            <div class="prof-gen-box">
              <div class="prof-gen-info">
                <div class="prof-gen-title">Generate Strong Password</div>
                <div class="prof-gen-sub">Secure 20-character password</div>
              </div>
              <button type="button" id="generatePwBtn" class="prof-gen-btn">Generate</button>
            </div>

            <div class="prof-pw-result" id="generatedPwBox">
              <div class="prof-pw-result-label">Generated Password</div>
              <div class="prof-pw-result-row">
                <code id="generatedPwText"></code>
                <button type="button" id="usePwBtn" class="prof-btn-sm prof-btn-use">Use This</button>
                <button type="button" id="copyPwBtn" class="prof-btn-sm prof-btn-copy">Copy</button>
              </div>
            </div>

            <button type="submit" class="prof-submit">Update Password</button>
          </form>
        </div>

        <!-- Right: Credentials & Security -->
        <div style="display:flex;flex-direction:column;gap:20px;">

          <!-- Credentials Download -->
          <div class="prof-section">
            <div class="prof-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M5.338 1.59a61 61 0 0 0-2.837.856.48.48 0 0 0-.328.39c-.554 4.157.726 7.19 2.253 9.188a10.7 10.7 0 0 0 2.287 2.233c.346.244.652.42.893.533q.18.085.293.118a1 1 0 0 0 .101.025 1 1 0 0 0 .1-.025q.114-.034.294-.118c.24-.113.547-.29.893-.533a10.7 10.7 0 0 0 2.287-2.233c1.527-1.997 2.807-5.031 2.253-9.188a.48.48 0 0 0-.328-.39c-.651-.213-1.75-.56-2.837-.855C9.552 1.29 8.531 1.067 8 1.067c-.53 0-1.552.223-2.662.524zM5.072.56C6.157.265 7.31 0 8 0s1.843.265 2.928.56c1.11.3 2.229.655 2.887.87a1.54 1.54 0 0 1 1.044 1.262c.596 4.477-.787 7.795-2.465 9.99a11.8 11.8 0 0 1-2.517 2.453 7 7 0 0 1-1.048.625c-.28.132-.581.24-.829.24s-.548-.108-.829-.24a7 7 0 0 1-1.048-.625 11.8 11.8 0 0 1-2.517-2.453C1.928 10.487.545 7.169 1.141 2.692A1.54 1.54 0 0 1 2.185 1.43 63 63 0 0 1 5.072.56"/><path d="M9.5 6.5a1.5 1.5 0 0 1-1 1.415l.385 1.99a.5.5 0 0 1-.491.595h-.788a.5.5 0 0 1-.49-.595l.384-1.99a1.5 1.5 0 1 1 2-1.415"/></svg>
              Credentials
            </div>
            <div class="cred-card">
              <div class="cred-icon" style="background:rgba(204,0,0,.12);color:#ff5555;">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="currentColor" viewBox="0 0 16 16"><path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/></svg>
              </div>
              <div class="cred-info">
                <div class="cred-title">Admin Credentials PDF</div>
                <div class="cred-desc">Download a secure PDF with your admin login URL, email, and password reference.</div>
              </div>
              <button class="cred-btn cred-btn-red" id="credPdfBtn">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
                Download
              </button>
            </div>
          </div>

          <!-- Security Notes -->
          <div class="prof-section">
            <div class="prof-section-title">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M8 16A8 8 0 1 0 8 0a8 8 0 0 0 0 16m.93-9.412-1 4.705c-.07.34.029.533.304.533.194 0 .487-.07.686-.246l-.088.416c-.287.346-.92.598-1.465.598-.703 0-1.002-.422-.808-1.319l.738-3.468c.064-.293.006-.399-.287-.399l-.502.001-.09-.42 1.91-.472zM8 5.5a1 1 0 1 1 0-2 1 1 0 0 1 0 2"/></svg>
              Security Notes
            </div>
            <div class="sec-note"><span class="sec-icon" style="color:#ffd700;">!</span> <span>Passwords are hashed and stored securely. Changes take effect immediately.</span></div>
            <div class="sec-note"><span class="sec-icon" style="color:#55ddaa;">+</span> <span>Use at least 12 characters. Generated passwords are 20 characters with mixed case, digits, and symbols.</span></div>
            <div class="sec-note"><span class="sec-icon" style="color:#55ddaa;">+</span> <span>After changing your password, you'll need the new one on next login. Keep it safe.</span></div>
            <div class="sec-note"><span class="sec-icon" style="color:#6699ff;">i</span> <span>To change the admin email, go to <a href="/admin/accounts" style="color:#6699ff;text-decoration:underline;">Account Management</a>.</span></div>
          </div>

        </div>
      </div>

    </div>
  </main>
</div>

<!-- Download Modal -->
<div class="dl-overlay" id="dlOverlay">
  <div class="dl-modal">
    <div class="dl-modal-icon" id="dlIcon">
      <div class="dl-spinner" id="dlSpinner"></div>
      <svg id="dlSuccessIcon" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"/></svg>
      <svg id="dlErrorIcon" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/><path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/></svg>
    </div>
    <div class="dl-modal-title" id="dlTitle">Generating PDF</div>
    <div class="dl-modal-msg" id="dlMsg">Preparing your document...</div>
    <div class="dl-modal-filename" id="dlFilename"></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script>
/* ── Clock ── */
function tick(){const e=new Date;document.getElementById('admClock').textContent=e.toLocaleTimeString('en-NG',{hour:'2-digit',minute:'2-digit'})+' · '+e.toLocaleDateString('en-NG',{day:'2-digit',month:'short',year:'numeric'})}tick();setInterval(tick,1000);

/* ── Sidebar toggle ── */
const sidebar=document.getElementById('admSidebar'),overlay=document.getElementById('admOverlay'),hamburger=document.getElementById('admHamburger');
hamburger.addEventListener('click',()=>{sidebar.classList.toggle('open');overlay.classList.toggle('open');document.body.style.overflow=sidebar.classList.contains('open')?'hidden':''});
overlay.addEventListener('click',()=>{sidebar.classList.remove('open');overlay.classList.remove('open');document.body.style.overflow=''});

/* ── Show/hide password toggles ── */
var eyeOpen='<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M10.5 8a2.5 2.5 0 1 1-5 0 2.5 2.5 0 0 1 5 0"/><path d="M0 8s3-5.5 8-5.5S16 8 16 8s-3 5.5-8 5.5S0 8 0 8m8 3.5a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7"/></svg>';
var eyeSlash='<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16"><path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z"/><path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829"/><path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709z"/><path d="m10.79 12.912-1.614-1.615a3.5 3.5 0 0 1-4.474-4.474l-2.06-2.06L.646 2.767l1.414-1.414 12.728 12.728-1.414 1.414-2.585-2.584zM5.525 7.646a2.5 2.5 0 0 0 2.829 2.829z"/></svg>';
document.querySelectorAll('.pw-toggle').forEach(btn=>{
  btn.addEventListener('click',()=>{
    const inp=document.getElementById(btn.dataset.target);
    const showing=inp.type==='password';
    inp.type=showing?'text':'password';
    btn.innerHTML=showing?eyeSlash:eyeOpen;
  });
});

/* ── Strength meter ── */
const newPwEl=document.getElementById('newPassword'),bar=document.getElementById('pwStrengthBar'),lbl=document.getElementById('pwStrengthLabel');
newPwEl.addEventListener('input',()=>{
  const v=newPwEl.value,l=v.length;
  let score=0;
  if(l>=8)score++;if(l>=12)score++;if(l>=16)score++;
  if(/[A-Z]/.test(v))score++;if(/[a-z]/.test(v))score++;
  if(/[0-9]/.test(v))score++;if(/[^A-Za-z0-9]/.test(v))score++;
  const pct=Math.round(score/7*100);
  const colors=['#ff5555','#ff5555','#ffd700','#ffd700','#00b87a','#00b87a','#00c878','#00c878'];
  const labels=['','Too short','Weak','Fair','Good','Strong','Very Strong','Excellent'];
  bar.style.width=pct+'%';bar.style.background=colors[score]||'#888';
  lbl.textContent=l?labels[score]||'Strong':'';lbl.style.color=colors[score]||'var(--muted)';
});

/* ── Generate password ── */
document.getElementById('generatePwBtn').addEventListener('click',()=>{
  fetch('/admin/api/generate-password',{credentials:'same-origin'})
    .then(r=>r.json()).then(res=>{
      if(res.password){
        document.getElementById('generatedPwText').textContent=res.password;
        document.getElementById('generatedPwBox').style.display='';
      }
    }).catch(()=>{});
});

document.getElementById('usePwBtn').addEventListener('click',()=>{
  const pwd=document.getElementById('generatedPwText').textContent;
  newPwEl.value=pwd;newPwEl.type='text';
  newPwEl.dispatchEvent(new Event('input'));
});

document.getElementById('copyPwBtn').addEventListener('click',()=>{
  const pwd=document.getElementById('generatedPwText').textContent;
  navigator.clipboard.writeText(pwd).then(()=>{
    const btn=document.getElementById('copyPwBtn');
    btn.textContent='Copied!';setTimeout(()=>btn.textContent='Copy',2000);
  }).catch(()=>{});
});

/* ── Download modal helpers ── */
var dlOverlay=document.getElementById('dlOverlay'),dlIcon=document.getElementById('dlIcon'),dlSpinner=document.getElementById('dlSpinner'),dlSuccessIc=document.getElementById('dlSuccessIcon'),dlErrorIc=document.getElementById('dlErrorIcon'),dlTitle=document.getElementById('dlTitle'),dlMsg=document.getElementById('dlMsg'),dlFilename=document.getElementById('dlFilename');
var MIN_MS=1500;
function fileStamp(){var d=new Date();return d.getFullYear()+String(d.getMonth()+1).padStart(2,'0')+String(d.getDate()).padStart(2,'0')+'-'+String(d.getHours()).padStart(2,'0')+String(d.getMinutes()).padStart(2,'0')+String(d.getSeconds()).padStart(2,'0')}
function fmtDate(iso){var d=new Date(iso);return d.toLocaleDateString('en-NG',{day:'2-digit',month:'short',year:'numeric'})+' '+d.toLocaleTimeString('en-NG',{hour:'2-digit',minute:'2-digit'})}
function showDl(f,l){dlIcon.className='dl-modal-icon';dlSpinner.style.display='';dlSuccessIc.style.display='none';dlErrorIc.style.display='none';dlTitle.textContent='Preparing '+l;dlMsg.textContent='Building document...';dlFilename.textContent=f;dlOverlay.classList.add('open')}
function showOk(f,l){dlIcon.className='dl-modal-icon success';dlSpinner.style.display='none';dlSuccessIc.style.display='';dlTitle.textContent='Download Complete';dlMsg.textContent='Your '+l+' file has been saved.';dlFilename.textContent=f;setTimeout(()=>dlOverlay.classList.remove('open'),2000)}
function showErr(m){dlIcon.className='dl-modal-icon error';dlSpinner.style.display='none';dlErrorIc.style.display='';dlTitle.textContent='Download Failed';dlMsg.textContent=m||'Something went wrong.';dlFilename.textContent='';setTimeout(()=>dlOverlay.classList.remove('open'),2500)}
function delayThen(start,fn){setTimeout(fn,Math.max(0,MIN_MS-(Date.now()-start)))}
function triggerBlob(blob,name){var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name;document.body.appendChild(a);a.click();document.body.removeChild(a);setTimeout(()=>URL.revokeObjectURL(a.href),1000)}

/* ── Load fonts for PDF ── */
var _whiteLogo=null,_logoAspect=1;
var _logoReady=new Promise(resolve=>{var img=new Image();img.crossOrigin='anonymous';img.onload=function(){_logoAspect=img.width/img.height;var c=document.createElement('canvas');c.width=img.width;c.height=img.height;var ctx=c.getContext('2d');ctx.drawImage(img,0,0);var d=ctx.getImageData(0,0,c.width,c.height);for(var i=0;i<d.data.length;i+=4){d.data[i]=255;d.data[i+1]=255;d.data[i+2]=255}ctx.putImageData(d,0,0);_whiteLogo=c.toDataURL('image/png');resolve()};img.onerror=resolve;img.src='/images/tsa-logo.png'});

var _bebasB64=null,_jakartaRegB64=null,_jakartaBoldB64=null;
function loadFontB64(url){return fetch(url).then(r=>r.arrayBuffer()).then(buf=>{var b=new Uint8Array(buf),s='';for(var i=0;i<b.length;i++)s+=String.fromCharCode(b[i]);return btoa(s)})}
var _fontsReady=Promise.all([
  loadFontB64('/fonts/BebasNeue-Regular.ttf').then(b=>{_bebasB64=b}),
  loadFontB64('/fonts/PlusJakartaSans-Regular.ttf').then(b=>{_jakartaRegB64=b}),
  loadFontB64('/fonts/PlusJakartaSans-Bold.ttf').then(b=>{_jakartaBoldB64=b})
]).catch(()=>{});
function regFonts(doc){if(_bebasB64){doc.addFileToVFS('BebasNeue.ttf',_bebasB64);doc.addFont('BebasNeue.ttf','BebasNeue','normal')}if(_jakartaRegB64){doc.addFileToVFS('PlusJakartaSans-Reg.ttf',_jakartaRegB64);doc.addFont('PlusJakartaSans-Reg.ttf','PlusJakartaSans','normal')}if(_jakartaBoldB64){doc.addFileToVFS('PlusJakartaSans-Bold.ttf',_jakartaBoldB64);doc.addFont('PlusJakartaSans-Bold.ttf','PlusJakartaSans','bold')}}
var TF=()=>_bebasB64?'BebasNeue':'helvetica';
var BF=()=>_jakartaRegB64?'PlusJakartaSans':'helvetica';

/* ── Credentials PDF download ── */
document.getElementById('credPdfBtn').addEventListener('click', function(e) {
  e.preventDefault();
  var stamp = fileStamp(), f = 'yw26-credentials-' + stamp + '.pdf', start = Date.now();
  showDl(f, 'PDF');
  Promise.all([_logoReady, _fontsReady,
    fetch('/admin/api/credentials', {credentials:'same-origin'}).then(function(r){return r.json()})
  ]).then(function(results) {
    var creds = results[2];
    try {
      var jsPDF = window.jspdf.jsPDF,
          doc = new jsPDF({unit:'mm', format:'a4'}),
          pw = doc.internal.pageSize.getWidth(),
          ph = doc.internal.pageSize.getHeight(),
          generated = fmtDate(new Date().toISOString());
      regFonts(doc);
      /* header band */
      for(var i=0;i<80;i++){var r=Math.round(10+i/80*194);doc.setFillColor(r,Math.max(0,10-i/80*10),Math.max(0,40-i/80*40));doc.rect(i*pw/80,0,pw/80+.5,34,'F')}
      if(_whiteLogo){var lh=22,lw=lh*_logoAspect;doc.addImage(_whiteLogo,'PNG',14,6,lw,lh)}
      doc.setFont(TF(),'normal');doc.setFontSize(22);doc.setTextColor(255,255,255);doc.text('ADMIN CREDENTIALS',42,16);
      doc.setFont(BF(),'normal');doc.setFontSize(10);doc.setTextColor(255,200,200);doc.text('IBCC Youth Week 26 — Confidential',42,24);
      doc.setFillColor(204,0,0);doc.rect(0,34,pw,2,'F');
      /* body */
      var y = 52;
      doc.setFont(BF(),'bold');doc.setFontSize(11);doc.setTextColor(80,80,100);doc.text('Login URL',20,y);
      doc.setFont(BF(),'normal');doc.setFontSize(12);doc.setTextColor(30,30,50);doc.text(window.location.origin + '/admin/login',20,y+8);
      y += 24;
      doc.setFont(BF(),'bold');doc.setFontSize(11);doc.setTextColor(80,80,100);doc.text('Email',20,y);
      doc.setFont(BF(),'normal');doc.setFontSize(12);doc.setTextColor(30,30,50);doc.text(creds.email || '—',20,y+8);
      y += 24;
      doc.setFont(BF(),'bold');doc.setFontSize(11);doc.setTextColor(80,80,100);doc.text('Password',20,y);
      doc.setFont(BF(),'normal');doc.setFontSize(12);doc.setTextColor(30,30,50);doc.text(creds.password || '—',20,y+8);
      /* footer */
      doc.setFont(BF(),'normal');doc.setFontSize(8);doc.setTextColor(150,150,170);
      doc.text('Generated: ' + generated,20,ph-12);
      doc.text('Keep this document secure. Do not share publicly.',20,ph-7);
      var blob = doc.output('blob');
      delayThen(start, function(){triggerBlob(blob,f);showOk(f,'PDF');fetch('/admin/api/log-download',{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json','X-CSRF-Token':document.querySelector('meta[name="csrf-token"]').content},body:JSON.stringify({type:'PDF',dataset:'credentials',filename:f})}).catch(function(){})});
    } catch(err) { delayThen(start, function(){showErr(err.message)}); }
  }).catch(function(err){ delayThen(start, function(){showErr(err.message)}); });
});
</script>
</body>
</html>
