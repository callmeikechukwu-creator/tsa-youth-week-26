<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title><%= title %> — IBCC Youth Week 26</title>
  <link rel="icon" type="image/png" href="/images/tsa-logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin-registrant.min.css">
</head>
<body>

<div class="adm-overlay" id="admOverlay"></div>

<div class="adm-layout">

  <% locals.activePage = 'registrations'; locals.regCount = locals.regCount || ''; locals.contactCount = locals.contactCount || ''; %>
  <%- include('partials/sidebar') %>

  <!-- Main -->
  <main class="adm-main">

    <div class="adm-topbar">
      <div class="adm-topbar-left">
        <button class="adm-hamburger" id="admHamburger" aria-label="Toggle menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/></svg>
        </button>
        <a href="/admin" class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M15 8a.5.5 0 0 0-.5-.5H2.707l3.147-3.146a.5.5 0 1 0-.708-.708l-4 4a.5.5 0 0 0 0 .708l4 4a.5.5 0 0 0 .708-.708L2.707 8.5H14.5A.5.5 0 0 0 15 8"/></svg>
          Back to Dashboard
        </a>
        <h1>REGISTRANT</h1>
      </div>
      <div class="adm-topbar-right">
        <button class="btn-outline" id="exportPdfBtn">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16"><path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/></svg>
          Export PDF
        </button>
        <button class="btn-del" id="delBtn">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
          Delete
        </button>
      </div>
    </div>

    <div class="adm-content">

      <!-- Header -->
      <div class="detail-header">
        <div class="detail-avatar"><%= entry.name.charAt(0).toUpperCase() %></div>
        <div class="detail-header-info">
          <h2><%= entry.name %></h2>
          <p><%= entry.email %> &nbsp;·&nbsp; Registered <%= new Date(entry.createdAt).toLocaleDateString('en-NG',{day:'2-digit',month:'long',year:'numeric'}) %></p>
        </div>
      </div>

      <!-- Details -->
      <div class="adm-card">
        <div class="adm-card-title">Registration Details</div>
        <div class="detail-grid">

          <div class="detail-field" style="padding-right:24px;">
            <div class="detail-field-label">Full Name</div>
            <div class="detail-field-value"><strong><%= entry.name %></strong></div>
          </div>

          <div class="detail-field" style="padding-left:24px;">
            <div class="detail-field-label">Email Address</div>
            <div class="detail-field-value"><%= entry.email %></div>
          </div>

          <div class="detail-field" style="padding-right:24px;">
            <div class="detail-field-label">Age Group</div>
            <div class="detail-field-value"><span class="adm-badge blue"><%= entry.age %></span></div>
          </div>

          <div class="detail-field" style="padding-left:24px;">
            <div class="detail-field-label">Church / Corps</div>
            <div class="detail-field-value muted"><%= entry.church || '—' %></div>
          </div>

          <div class="detail-field" style="padding-right:24px;">
            <div class="detail-field-label">Participation Role</div>
            <div class="detail-field-value">
              <span class="adm-badge <%= entry.role==='attendee'?'green':entry.role==='volunteer'?'gold':entry.role==='musician'?'blue':'red' %>">
                <%= entry.role %>
              </span>
            </div>
          </div>

          <div class="detail-field" style="padding-left:24px;">
            <div class="detail-field-label">Heard Via</div>
            <div class="detail-field-value muted"><%= entry.heard || '—' %></div>
          </div>

          <div class="detail-field" style="padding-right:24px;">
            <div class="detail-field-label">Record ID</div>
            <div class="detail-field-value muted" style="font-family:var(--font-d);font-size:15px;letter-spacing:1px;"><%= entry.id %></div>
          </div>

          <div class="detail-field" style="padding-left:24px;">
            <div class="detail-field-label">Date Registered</div>
            <div class="detail-field-value muted"><%= new Date(entry.createdAt).toLocaleString('en-NG',{day:'2-digit',month:'long',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></div>
          </div>

        </div>
      </div>

    </div>
  </main>

</div>

<!-- Delete Confirmation Modal -->
<div class="del-overlay" id="delOverlay">
  <div class="del-modal">
    <div class="del-modal-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg>
    </div>
    <h3 class="del-modal-title">Delete Registration</h3>
    <p class="del-modal-msg">Are you sure you want to permanently delete this registration? This action cannot be undone.</p>
    <div class="del-modal-id"><%= entry.id %></div>
    <div class="del-modal-actions">
      <button class="del-btn-cancel" id="delCancel">Cancel</button>
      <button class="del-btn-confirm" id="delConfirm">Delete</button>
    </div>
  </div>
</div>

<script>
  const sidebar   = document.getElementById('admSidebar');
  const overlay   = document.getElementById('admOverlay');
  const hamburger = document.getElementById('admHamburger');
  function openSidebar() { sidebar.classList.add('open'); overlay.classList.add('open'); document.body.style.overflow='hidden'; }
  function closeSidebar(){ sidebar.classList.remove('open'); overlay.classList.remove('open'); document.body.style.overflow=''; }
  hamburger.addEventListener('click', () => sidebar.classList.contains('open') ? closeSidebar() : openSidebar());
  overlay.addEventListener('click', closeSidebar);

  // ── Delete logic ──
  const delOverlay = document.getElementById('delOverlay');
  const delCancel  = document.getElementById('delCancel');
  const delConfirm = document.getElementById('delConfirm');

  document.getElementById('delBtn').addEventListener('click', function() {
    delConfirm.disabled = false;
    delConfirm.textContent = 'Delete';
    delOverlay.classList.add('open');
  });

  delCancel.addEventListener('click', function() { delOverlay.classList.remove('open'); });
  delOverlay.addEventListener('click', function(e) { if (e.target === delOverlay) delOverlay.classList.remove('open'); });

  delConfirm.addEventListener('click', function() {
    delConfirm.disabled = true;
    delConfirm.textContent = 'Deleting...';

    fetch('/admin/registrations/<%= entry.id %>', {
      method: 'DELETE',
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content }
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.success) {
        window.location.href = '/admin';
      } else {
        delConfirm.textContent = 'Failed';
        setTimeout(function() { delConfirm.textContent = 'Delete'; delConfirm.disabled = false; }, 1500);
      }
    })
    .catch(function() {
      delConfirm.textContent = 'Error';
      setTimeout(function() { delConfirm.textContent = 'Delete'; delConfirm.disabled = false; }, 1500);
    });
  });
</script>

<!-- PDF Download Modal -->
<div class="dl-overlay" id="dlOverlay">
  <div class="dl-modal">
    <div class="dl-modal-icon" id="dlIcon">
      <div class="dl-spinner" id="dlSpinner"></div>
      <svg id="dlSuccessIcon" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"/></svg>
      <svg id="dlErrorIcon" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/><path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/></svg>
    </div>
    <div class="dl-modal-title" id="dlTitle">Generating PDF</div>
    <div class="dl-modal-msg" id="dlMsg">Preparing your document...</div>
    <div class="dl-modal-filename" id="dlFilename"></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.4/jspdf.plugin.autotable.min.js"></script>
<script>
(function() {
  var dlOverlay   = document.getElementById('dlOverlay');
  var dlIcon      = document.getElementById('dlIcon');
  var dlSpinner   = document.getElementById('dlSpinner');
  var dlSuccessIc = document.getElementById('dlSuccessIcon');
  var dlErrorIc   = document.getElementById('dlErrorIcon');
  var dlTitle     = document.getElementById('dlTitle');
  var dlMsg       = document.getElementById('dlMsg');
  var dlFilename  = document.getElementById('dlFilename');

  var __entry = JSON.parse('<%- JSON.stringify(entry).replace(/\\/g, "\\\\\\\\").replace(/\'/g, "\\\\u0027").replace(/</g, "\\\\u003c").replace(/>/g, "\\\\u003e") %>');
  var MIN_LOADING_MS = 1500;

  function fileStamp() {
    var d = new Date();
    return d.getFullYear().toString() +
      String(d.getMonth()+1).padStart(2,'0') +
      String(d.getDate()).padStart(2,'0') + '-' +
      String(d.getHours()).padStart(2,'0') +
      String(d.getMinutes()).padStart(2,'0') +
      String(d.getSeconds()).padStart(2,'0');
  }

  function fmtDate(iso) {
    var d = new Date(iso);
    return d.toLocaleDateString('en-NG',{day:'2-digit',month:'short',year:'numeric'}) +
      ' ' + d.toLocaleTimeString('en-NG',{hour:'2-digit',minute:'2-digit'});
  }

  function showDlModal(fname) {
    dlIcon.className = 'dl-modal-icon';
    dlSpinner.style.display = 'block';
    dlSuccessIc.style.display = 'none';
    dlErrorIc.style.display = 'none';
    dlTitle.textContent = 'Generating PDF';
    dlMsg.textContent = 'Preparing your document...';
    dlFilename.textContent = fname;
    dlOverlay.classList.add('open');
  }
  function showSuccess(fname) {
    dlIcon.className = 'dl-modal-icon success';
    dlSpinner.style.display = 'none';
    dlSuccessIc.style.display = 'block';
    dlTitle.textContent = 'Download Complete';
    dlMsg.textContent = 'Your PDF has been saved.';
    dlFilename.textContent = fname;
    setTimeout(function() { dlOverlay.classList.remove('open'); }, 2000);
  }
  function showError(msg) {
    dlIcon.className = 'dl-modal-icon error';
    dlSpinner.style.display = 'none';
    dlErrorIc.style.display = 'block';
    dlTitle.textContent = 'Download Failed';
    dlMsg.textContent = msg || 'Something went wrong.';
    dlFilename.textContent = '';
    setTimeout(function() { dlOverlay.classList.remove('open'); }, 2500);
  }

  function delayThen(start, fn) {
    var elapsed = Date.now() - start;
    var wait = Math.max(0, MIN_LOADING_MS - elapsed);
    if (wait > 0) setTimeout(fn, wait); else fn();
  }

  /* ── Load brand fonts ── */
  var _bebasB64 = null, _jakartaRegB64 = null, _jakartaBoldB64 = null;

  function loadFontAsBase64(url) {
    return fetch(url)
      .then(function(r) { return r.arrayBuffer(); })
      .then(function(buf) {
        var bytes = new Uint8Array(buf);
        var binary = '';
        for (var i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
        return btoa(binary);
      });
  }

  var _fontsReady = Promise.all([
    loadFontAsBase64('/fonts/BebasNeue-Regular.ttf').then(function(b) { _bebasB64 = b; }),
    loadFontAsBase64('/fonts/PlusJakartaSans-Regular.ttf').then(function(b) { _jakartaRegB64 = b; }),
    loadFontAsBase64('/fonts/PlusJakartaSans-Bold.ttf').then(function(b) { _jakartaBoldB64 = b; })
  ]).catch(function() {});

  function registerFonts(doc) {
    if (_bebasB64) {
      doc.addFileToVFS('BebasNeue-Regular.ttf', _bebasB64);
      doc.addFont('BebasNeue-Regular.ttf', 'BebasNeue', 'normal');
    }
    if (_jakartaRegB64) {
      doc.addFileToVFS('PlusJakartaSans-Regular.ttf', _jakartaRegB64);
      doc.addFont('PlusJakartaSans-Regular.ttf', 'PlusJakartaSans', 'normal');
    }
    if (_jakartaBoldB64) {
      doc.addFileToVFS('PlusJakartaSans-Bold.ttf', _jakartaBoldB64);
      doc.addFont('PlusJakartaSans-Bold.ttf', 'PlusJakartaSans', 'bold');
    }
  }

  var _titleFont = function() { return _bebasB64 ? 'BebasNeue' : 'helvetica'; };
  var _bodyFont  = function() { return _jakartaRegB64 ? 'PlusJakartaSans' : 'helvetica'; };

  /* ── White logo (preserve aspect ratio) ── */
  var _whiteLogo = null;
  var _logoAspect = 1;
  var _logoReady = new Promise(function(resolve) {
    var img = new Image();
    img.crossOrigin = 'anonymous';
    img.onload = function() {
      _logoAspect = img.width / img.height;
      var c = document.createElement('canvas');
      c.width = img.width; c.height = img.height;
      var ctx = c.getContext('2d');
      ctx.drawImage(img, 0, 0);
      var data = ctx.getImageData(0, 0, c.width, c.height);
      for (var i = 0; i < data.data.length; i += 4) {
        data.data[i] = 255; data.data[i+1] = 255; data.data[i+2] = 255;
      }
      ctx.putImageData(data, 0, 0);
      _whiteLogo = c.toDataURL('image/png');
      resolve();
    };
    img.onerror = function() { resolve(); };
    img.src = '/images/tsa-logo.png';
  });

  document.getElementById('exportPdfBtn').addEventListener('click', function() {
    var filename = 'yw26-reg-' + __entry.id + '-' + fileStamp() + '.pdf';
    var startTime = Date.now();
    showDlModal(filename);

    Promise.all([_logoReady, _fontsReady]).then(function() {
      dlMsg.textContent = 'Rendering document...';
      var blob;
      try {
        var jsPDF = window.jspdf.jsPDF;
        var doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
        registerFonts(doc);
        var pw = doc.internal.pageSize.getWidth();
        var generated = fmtDate(new Date().toISOString());

        // Header gradient
        var steps = 80, h = 28;
        for (var i = 0; i < steps; i++) {
          var ratio = i / steps;
          var r = Math.round(10 + ratio * 194);
          var g = Math.round(10 - ratio * 10);
          var b = Math.round(40 - ratio * 40);
          doc.setFillColor(r, Math.max(0,g), Math.max(0,b));
          doc.rect(i * pw / steps, 0, pw / steps + 0.5, h, 'F');
        }
        if (_whiteLogo) {
          var logoH = 18, logoW = logoH * _logoAspect;
          doc.addImage(_whiteLogo, 'PNG', 10, 5, logoW, logoH);
        }
        doc.setFont(_titleFont(), 'normal');
        doc.setFontSize(16);
        doc.setTextColor(255,255,255);
        doc.text('REGISTRATION DETAILS FOR ' + __entry.name.toUpperCase(), 34, 13);
        doc.setFont(_bodyFont(), 'normal');
        doc.setFontSize(9);
        doc.setTextColor(255,200,200);
        doc.text('IBCC Youth Week 26', 34, 19);

        // Accent bar
        doc.setFillColor(204,0,0);
        doc.rect(0, h, pw, 2, 'F');

        // Meta bar
        doc.setFillColor(245,245,250);
        doc.rect(0, h+2, pw, 10, 'F');
        doc.setFont(_bodyFont(), 'normal');
        doc.setFontSize(8);
        doc.setTextColor(100,100,130);
        doc.text('Record: ' + __entry.id, 10, h+8.5);
        doc.text('Generated: ' + generated, pw - 10, h+8.5, { align: 'right' });

        var startY = h + 16;

        // Detail fields table
        var fields = [
          ['Full Name', __entry.name],
          ['Email Address', __entry.email],
          ['Age Group', __entry.age],
          ['Church / Corps', __entry.church || '\u2014'],
          ['Participation Role', __entry.role],
          ['Heard Via', __entry.heard || '\u2014'],
          ['Record ID', __entry.id],
          ['Date Registered', fmtDate(__entry.createdAt)]
        ];

        doc.autoTable({
          body: fields,
          startY: startY,
          theme: 'plain',
          styles: {
            font: _bodyFont(),
            fontSize: 10,
            cellPadding: { top: 5, bottom: 5, left: 10, right: 10 },
            textColor: [30,30,50],
            lineColor: [230,230,240],
            lineWidth: 0.2
          },
          columnStyles: {
            0: { fontStyle: 'bold', cellWidth: 55, textColor: [100,100,130], fontSize: 9 },
            1: { cellWidth: 'auto' }
          },
          didParseCell: function(data) {
            data.cell.styles.lineWidth = { bottom: 0.2, top: 0, left: 0, right: 0 };
          },
          margin: { left: 15, right: 15 }
        });

        // Footer
        var ph = doc.internal.pageSize.getHeight();
        doc.setFont(_bodyFont(), 'normal');
        doc.setFontSize(7);
        doc.setTextColor(150,150,170);
        doc.text('IBCC Youth Week 26 \u2014 Registration Detail', 10, ph - 8);
        doc.text('Page 1', pw - 10, ph - 8, { align: 'right' });

        blob = doc.output('blob');
      } catch(err) {
        delayThen(startTime, function() { showError(err.message || 'PDF generation failed.'); });
        return;
      }
      delayThen(startTime, function() {
        try {
          var a = document.createElement('a');
          a.href = URL.createObjectURL(blob);
          a.download = filename;
          document.body.appendChild(a);
          a.click();
          document.body.removeChild(a);
          setTimeout(function() { URL.revokeObjectURL(a.href); }, 1000);
          showSuccess(filename);
          fetch('/admin/api/log-download',{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json','X-CSRF-Token':document.querySelector('meta[name="csrf-token"]').content},body:JSON.stringify({type:'PDF',dataset:'registrations',filename:filename})}).catch(function(){});
        } catch(err) {
          showError('Failed to save file: ' + (err.message || 'unknown error'));
        }
      });
    }).catch(function(err) {
      showError('Failed to load resources: ' + (err.message || 'unknown error'));
    });
  });
})();
</script>
</body>
</html>
