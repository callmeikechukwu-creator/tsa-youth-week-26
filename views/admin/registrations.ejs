<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
  <title>Registrations — Admin · IBCC Youth Week 26</title>
  <link rel="icon" type="image/png" href="/images/tsa-logo.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.min.css">
</head>
<body>

<div class="adm-overlay" id="admOverlay"></div>
<div class="adm-layout">

  <% locals.activePage = 'registrations'; locals.regCount = registrations.length; %>
  <%- include('partials/sidebar') %>

  <main class="adm-main">
    <div class="adm-topbar">
      <div class="adm-topbar-left">
        <button class="adm-hamburger" id="admHamburger" aria-label="Toggle menu">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/></svg>
        </button>
        <h1>REGISTRATIONS</h1>
      </div>
      <div class="adm-topbar-right">
        <span class="adm-time" id="admClock"></span>
      </div>
    </div>

    <div class="adm-content">

      <!-- Stats bar -->
      <div class="adm-stats" style="margin-bottom:20px;">
        <div class="adm-stat s-red">
          <div class="adm-stat-icon" style="background:rgba(204,0,0,.2);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#ff5555" viewBox="0 0 16 16"><path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.24 2.24 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.3 6.3 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1zM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5"/></svg>
          </div>
          <div class="adm-stat-label">Total</div>
          <div class="adm-stat-value red"><%= registrations.length %></div>
        </div>
        <% const roles = {}; registrations.forEach(r => { roles[r.role] = (roles[r.role]||0)+1; }); %>
        <% const topRole = Object.entries(roles).sort((a,b)=>b[1]-a[1])[0]; %>
        <div class="adm-stat s-blue">
          <div class="adm-stat-icon" style="background:rgba(0,100,255,.2);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#6699ff" viewBox="0 0 16 16"><path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm8-9a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/></svg>
          </div>
          <div class="adm-stat-label">Top Role</div>
          <div class="adm-stat-value blue" style="font-size:18px;"><%= topRole ? topRole[0] : '—' %></div>
        </div>
        <% const ages = {}; registrations.forEach(r => { ages[r.age] = (ages[r.age]||0)+1; }); %>
        <div class="adm-stat s-gold">
          <div class="adm-stat-icon" style="background:rgba(200,162,0,.15);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#ffcc44" viewBox="0 0 16 16"><path d="M8 1a2.5 2.5 0 0 1 2.5 2.5V4h-5v-.5A2.5 2.5 0 0 1 8 1m3.5 3v-.5a3.5 3.5 0 1 0-7 0V4H1v10h14V4zM2 5h12v8H2z"/></svg>
          </div>
          <div class="adm-stat-label">Age Groups</div>
          <div class="adm-stat-value gold"><%= Object.keys(ages).length %></div>
        </div>
        <div class="adm-stat s-green">
          <div class="adm-stat-icon" style="background:rgba(0,180,120,.15);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="#55ddaa" viewBox="0 0 16 16"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
          </div>
          <div class="adm-stat-label">Downloads</div>
          <div class="adm-stat-value green"><%= logs.length %></div>
        </div>
      </div>

      <!-- Main card: search + table -->
      <div class="adm-card" style="margin-bottom:20px;">
        <div class="adm-card-head">
          <div class="adm-section-title">All Registrations <span style="color:var(--muted);font-size:16px;">(<%= registrations.length %>)</span></div>
          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <input type="text" id="regSearch" placeholder="Search name, email, church…"
              style="background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.12);color:var(--fg);padding:8px 14px;border-radius:8px;font-size:13px;font-family:inherit;width:220px;outline:none;">
            <div class="custom-dropdown" id="regFilterRoleDD" style="width:auto;min-width:140px;">
              <button type="button" class="custom-dropdown-trigger" tabindex="0">
                <span class="dd-text dd-placeholder">All Roles</span>
                <svg class="dd-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708"/></svg>
              </button>
              <div class="custom-dropdown-menu">
                <div class="custom-dropdown-item selected" data-value="">All Roles</div>
                <% const uniqueRoles = [...new Set(registrations.map(r=>r.role))]; %>
                <% uniqueRoles.forEach(role => { %><div class="custom-dropdown-item" data-value="<%= role %>"><%= role %></div><% }); %>
              </div>
            </div>
            <div class="custom-dropdown" id="regFilterAgeDD" style="width:auto;min-width:140px;">
              <button type="button" class="custom-dropdown-trigger" tabindex="0">
                <span class="dd-text dd-placeholder">All Ages</span>
                <svg class="dd-arrow" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor"><path fill-rule="evenodd" d="M1.646 4.646a.5.5 0 0 1 .708 0L8 10.293l5.646-5.647a.5.5 0 0 1 .708.708l-6 6a.5.5 0 0 1-.708 0l-6-6a.5.5 0 0 1 0-.708"/></svg>
              </button>
              <div class="custom-dropdown-menu">
                <div class="custom-dropdown-item selected" data-value="">All Ages</div>
                <% const uniqueAges = [...new Set(registrations.map(r=>r.age))]; %>
                <% uniqueAges.forEach(age => { %><div class="custom-dropdown-item" data-value="<%= age %>"><%= age %></div><% }); %>
              </div>
            </div>
          </div>
        </div>

        <% if (registrations.length === 0) { %>
          <div class="adm-empty">
            <div class="adm-empty-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16"><path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/></svg></div>
            <p>No registrations yet.</p>
          </div>
        <% } else { %>
          <div id="regCount" style="font-size:12px;color:var(--muted);margin-bottom:10px;"></div>
          <div class="adm-table-wrap">
            <table class="adm-table" id="regTable">
              <thead>
                <tr>
                  <th>#</th><th>ID</th><th>Name</th><th>Email</th><th>Age</th><th>Church / Corps</th><th>Role</th><th>Heard Via</th><th>Date</th><th></th>
                </tr>
              </thead>
              <tbody>
                <% registrations.forEach((r, i) => { %>
                <tr data-id="<%= r.id %>" data-type="registrations"
                    data-name="<%= r.name.toLowerCase() %>"
                    data-email="<%= (r.email||'').toLowerCase() %>"
                    data-church="<%= (r.church||'').toLowerCase() %>"
                    data-role="<%= r.role %>"
                    data-age="<%= r.age %>"
                    onclick="window.location='/admin/registrations/<%= r.id %>'">
                  <td style="color:var(--muted);font-size:11px;"><%= i+1 %></td>
                  <td><span class="adm-id-stamp"><%= r.id %></span></td>
                  <td><strong><%= r.name %></strong></td>
                  <td style="color:var(--muted);"><%= r.email %></td>
                  <td><span class="adm-badge blue"><%= r.age %></span></td>
                  <td style="color:var(--muted);"><%= r.church || '—' %></td>
                  <td><span class="adm-badge <%= r.role==='attendee'?'green':r.role==='volunteer'?'gold':r.role==='musician'?'blue':'red' %>"><%= r.role %></span></td>
                  <td style="color:var(--muted);"><%= r.heard || '—' %></td>
                  <td style="color:var(--muted);white-space:nowrap;font-size:12px;"><%= new Date(r.createdAt).toLocaleDateString('en-NG',{day:'2-digit',month:'short',year:'numeric'}) %></td>
                  <td>
                    <button class="adm-delete-btn" data-id="<%= r.id %>" data-type="registrations" onclick="event.stopPropagation();confirmDelete(this)" title="Delete">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M5.5 5.5A.5.5 0 0 1 6 6v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m2.5 0a.5.5 0 0 1 .5.5v6a.5.5 0 0 1-1 0V6a.5.5 0 0 1 .5-.5m3 .5a.5.5 0 0 0-1 0v6a.5.5 0 0 0 1 0z"/><path d="M14.5 3a1 1 0 0 1-1 1H13v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V4h-.5a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1H6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1h3.5a1 1 0 0 1 1 1zM4.118 4 4 4.059V13a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1V4.059L11.882 4zM2.5 3h11V2h-11z"/></svg>
                    </button>
                  </td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

      <!-- Downloads section -->
      <div class="adm-card" style="margin-bottom:20px;">
        <div class="adm-card-head">
          <div class="adm-section-title">Export Records</div>
        </div>
        <div style="display:flex;gap:12px;flex-wrap:wrap;margin-bottom:20px;">
          <a href="/admin/export/registrations" class="btn-red file-download-link<%= registrations.length===0?' disabled':'' %>" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:700;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M.5 9.9a.5.5 0 0 1 .5.5v2.5a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-2.5a.5.5 0 0 1 1 0v2.5a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2v-2.5a.5.5 0 0 1 .5-.5"/><path d="M7.646 11.854a.5.5 0 0 0 .708 0l3-3a.5.5 0 0 0-.708-.708L8.5 10.293V1.5a.5.5 0 0 0-1 0v8.793L5.354 8.146a.5.5 0 1 0-.708.708z"/></svg>
            Download CSV
          </a>
          <a href="/admin/export/registrations/json" class="btn-outline file-download-link<%= registrations.length===0?' disabled':'' %>" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:700;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M14 4.5V11h-1V4.5h-2A1.5 1.5 0 0 1 9.5 3V1H4a1 1 0 0 0-1 1v9H2V2a2 2 0 0 1 2-2h5.5z"/></svg>
            Download JSON
          </a>
          <a href="/admin/export/registrations/pdf" class="btn-outline pdf-download-link<%= registrations.length===0?' disabled':'' %>" style="text-decoration:none;display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:8px;font-size:13px;font-weight:700;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16"><path d="M14 14V4.5L9.5 0H4a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h8a2 2 0 0 0 2-2M9.5 3A1.5 1.5 0 0 0 11 4.5h2V14a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V2a1 1 0 0 1 1-1h5.5z"/></svg>
            Download PDF
          </a>
        </div>

        <!-- Download history -->
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--muted);margin-bottom:12px;">Download History</div>
        <% if (logs.length === 0) { %>
          <p style="color:var(--muted);font-size:13px;">No downloads recorded yet.</p>
        <% } else { %>
          <div class="adm-table-wrap">
            <table class="adm-table">
              <thead><tr><th>File</th><th>Type</th><th>Source</th><th>Date &amp; Time</th><th>IP</th></tr></thead>
              <tbody>
                <% logs.forEach(l => { %>
                <tr>
                  <td style="font-family:monospace;font-size:11px;color:var(--muted);"><%= l.filename %></td>
                  <td><span class="adm-badge <%= l.type==='CSV'?'green':l.type==='JSON'?'blue':'red' %>"><%= l.type %></span></td>
                  <td style="font-size:12px;color:var(--muted);text-transform:capitalize;"><%= l.dataset %></td>
                  <td style="font-size:12px;color:var(--muted);white-space:nowrap;"><%= new Date(l.createdAt).toLocaleString('en-NG',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'}) %></td>
                  <td style="font-size:11px;color:var(--muted);font-family:monospace;"><%= l.ip %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>

    </div><!-- /adm-content -->
  </main>
</div>

<!-- Delete Modal -->
<div class="del-overlay" id="delOverlay">
  <div class="del-modal">
    <div class="del-modal-icon"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16"><path d="M8.982 1.566a1.13 1.13 0 0 0-1.96 0L.165 13.233c-.457.778.091 1.767.98 1.767h13.713c.889 0 1.438-.99.98-1.767zM8 5c.535 0 .954.462.9.995l-.35 3.507a.552.552 0 0 1-1.1 0L7.1 5.995A.905.905 0 0 1 8 5m.002 6a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/></svg></div>
    <h3 class="del-modal-title">Delete Registration</h3>
    <p class="del-modal-msg">This action cannot be undone.</p>
    <div class="del-modal-id" id="delModalId"></div>
    <div class="del-modal-actions">
      <button class="del-btn-cancel" id="delCancel">Cancel</button>
      <button class="del-btn-confirm" id="delConfirm">Delete</button>
    </div>
  </div>
</div>

<!-- Download modal -->
<div class="dl-overlay" id="dlOverlay">
  <div class="dl-modal">
    <div class="dl-modal-icon" id="dlIcon"><div class="dl-spinner" id="dlSpinner"></div><svg id="dlSuccessIcon" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M12.736 3.97a.733.733 0 0 1 1.047 0c.286.289.29.756.01 1.05L7.88 12.01a.733.733 0 0 1-1.065.02L3.217 8.384a.757.757 0 0 1 0-1.06.733.733 0 0 1 1.047 0l3.052 3.093 5.4-6.425z"/></svg><svg id="dlErrorIcon" style="display:none;" xmlns="http://www.w3.org/2000/svg" width="28" height="28" fill="currentColor" viewBox="0 0 16 16"><path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/><path d="M7.002 11a1 1 0 1 1 2 0 1 1 0 0 1-2 0M7.1 4.995a.905.905 0 1 1 1.8 0l-.35 3.507a.552.552 0 0 1-1.1 0z"/></svg></div>
    <div class="dl-modal-title" id="dlTitle">Generating PDF</div>
    <div class="dl-modal-msg" id="dlMsg">Preparing your document...</div>
    <div class="dl-modal-filename" id="dlFilename"></div>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.4/jspdf.plugin.autotable.min.js"></script>
<script>
// Clock
function tick(){const e=new Date;document.getElementById('admClock').textContent=e.toLocaleTimeString('en-NG',{hour:'2-digit',minute:'2-digit'})+' · '+e.toLocaleDateString('en-NG',{day:'2-digit',month:'short',year:'numeric'})}tick();setInterval(tick,1000);
// Sidebar
const sidebar=document.getElementById('admSidebar'),overlay=document.getElementById('admOverlay'),hamburger=document.getElementById('admHamburger');
hamburger.addEventListener('click',()=>{sidebar.classList.toggle('open');overlay.classList.toggle('open');document.body.style.overflow=sidebar.classList.contains('open')?'hidden':''});
overlay.addEventListener('click',()=>{sidebar.classList.remove('open');overlay.classList.remove('open');document.body.style.overflow=''});

// Custom dropdown init
(function() {
  document.querySelectorAll('.custom-dropdown').forEach(function(dd) {
    var trigger = dd.querySelector('.custom-dropdown-trigger');
    var textEl = trigger.querySelector('.dd-text');
    var items = dd.querySelectorAll('.custom-dropdown-item');

    trigger.addEventListener('click', function(e) {
      e.preventDefault();
      var wasOpen = dd.classList.contains('open');
      document.querySelectorAll('.custom-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
      if (!wasOpen) dd.classList.add('open');
    });

    items.forEach(function(item) {
      item.addEventListener('click', function() {
        items.forEach(function(i) { i.classList.remove('selected'); });
        item.classList.add('selected');
        textEl.textContent = item.textContent;
        textEl.classList.remove('dd-placeholder');
        dd.classList.remove('open');
        dd.dispatchEvent(new Event('change'));
      });
    });

    trigger.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') dd.classList.remove('open');
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); trigger.click(); }
    });
  });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('.custom-dropdown')) {
      document.querySelectorAll('.custom-dropdown.open').forEach(function(d) { d.classList.remove('open'); });
    }
  });
})();

// Search & filter
const rows = Array.from(document.querySelectorAll('#regTable tbody tr'));
const searchEl = document.getElementById('regSearch');
const roleDd = document.getElementById('regFilterRoleDD');
const ageDd = document.getElementById('regFilterAgeDD');
const countEl = document.getElementById('regCount');
function getSelectedVal(dd) {
  var sel = dd.querySelector('.custom-dropdown-item.selected');
  return sel ? sel.dataset.value : '';
}
function filterTable() {
  const q = searchEl.value.toLowerCase().trim();
  const role = getSelectedVal(roleDd);
  const age = getSelectedVal(ageDd);
  let visible = 0;
  rows.forEach(row => {
    const matchQ = !q || row.dataset.name.includes(q) || row.dataset.email.includes(q) || row.dataset.church.includes(q);
    const matchRole = !role || row.dataset.role === role;
    const matchAge = !age || row.dataset.age === age;
    const show = matchQ && matchRole && matchAge;
    row.style.display = show ? '' : 'none';
    if (show) visible++;
  });
  if (countEl) countEl.textContent = visible + ' of ' + rows.length + ' records shown';
}
if (searchEl) { searchEl.addEventListener('input', filterTable); roleDd.addEventListener('change', filterTable); ageDd.addEventListener('change', filterTable); filterTable(); }

// Delete modal
const delOverlay=document.getElementById('delOverlay'),delModalId=document.getElementById('delModalId'),delCancel=document.getElementById('delCancel'),delConfirm=document.getElementById('delConfirm');
let pendingDelete=null;
function confirmDelete(e){pendingDelete={id:e.dataset.id,type:e.dataset.type};delModalId.textContent=e.dataset.id;delConfirm.disabled=false;delConfirm.textContent='Delete';delOverlay.classList.add('open')}
function closeDeleteModal(){delOverlay.classList.remove('open');pendingDelete=null}
delCancel.addEventListener('click',closeDeleteModal);
delOverlay.addEventListener('click',e=>{if(e.target===delOverlay)closeDeleteModal()});
delConfirm.addEventListener('click',function(){
  if(!pendingDelete)return;
  const {id,type}=pendingDelete;
  delConfirm.disabled=true;delConfirm.textContent='Deleting…';
  fetch('/admin/'+type+'/'+id,{method:'DELETE',headers:{Accept:'application/json','X-CSRF-Token':document.querySelector('meta[name="csrf-token"]').content}})
    .then(r=>r.json()).then(res=>{
      if(res.success){
        document.querySelectorAll('[data-id="'+id+'"]').forEach(el=>{
          if(el.tagName==='TR'){el.style.opacity=0;setTimeout(()=>el.remove(),300)}
        });
        closeDeleteModal();setTimeout(()=>location.reload(),400);
      } else {delConfirm.textContent='Failed';setTimeout(()=>{delConfirm.textContent='Delete';delConfirm.disabled=false},1500)}
    }).catch(()=>{delConfirm.textContent='Error';setTimeout(()=>{delConfirm.textContent='Delete';delConfirm.disabled=false},1500)});
});

// Download modal + PDF
var __registrations = JSON.parse('<%- JSON.stringify(registrations).replace(/\\/g,"\\\\\\\\").replace(/\'/g,"\\\\u0027").replace(/</g,"\\\\u003c").replace(/>/g,"\\\\u003e") %>');
var dlOverlay=document.getElementById('dlOverlay'),dlIcon=document.getElementById('dlIcon'),dlSpinner=document.getElementById('dlSpinner'),dlSuccessIc=document.getElementById('dlSuccessIcon'),dlErrorIc=document.getElementById('dlErrorIcon'),dlTitle=document.getElementById('dlTitle'),dlMsg=document.getElementById('dlMsg'),dlFilename=document.getElementById('dlFilename');
var MIN_MS=1500,_whiteLogo=null,_logoAspect=1;
var _logoReady=new Promise(resolve=>{var img=new Image();img.crossOrigin='anonymous';img.onload=function(){_logoAspect=img.width/img.height;var c=document.createElement('canvas');c.width=img.width;c.height=img.height;var ctx=c.getContext('2d');ctx.drawImage(img,0,0);var d=ctx.getImageData(0,0,c.width,c.height);for(var i=0;i<d.data.length;i+=4){d.data[i]=255;d.data[i+1]=255;d.data[i+2]=255}ctx.putImageData(d,0,0);_whiteLogo=c.toDataURL('image/png');resolve()};img.onerror=resolve;img.src='/images/tsa-logo.png'});
function fileStamp(){var d=new Date();return d.getFullYear()+String(d.getMonth()+1).padStart(2,'0')+String(d.getDate()).padStart(2,'0')+'-'+String(d.getHours()).padStart(2,'0')+String(d.getMinutes()).padStart(2,'0')+String(d.getSeconds()).padStart(2,'0')}
function fmtDate(iso){var d=new Date(iso);return d.toLocaleDateString('en-NG',{day:'2-digit',month:'short',year:'numeric'})+' '+d.toLocaleTimeString('en-NG',{hour:'2-digit',minute:'2-digit'})}
function showDl(filename,label){dlIcon.className='dl-modal-icon';dlSpinner.style.display='';dlSuccessIc.style.display='none';dlErrorIc.style.display='none';dlTitle.textContent='Preparing '+label;dlMsg.textContent='Building document…';dlFilename.textContent=filename;dlOverlay.classList.add('open')}
function showOk(f,l){dlIcon.className='dl-modal-icon success';dlSpinner.style.display='none';dlSuccessIc.style.display='';dlTitle.textContent='Download Complete';dlMsg.textContent='Your '+l+' file has been saved.';dlFilename.textContent=f;setTimeout(()=>dlOverlay.classList.remove('open'),2000)}
function showErr(m){dlIcon.className='dl-modal-icon error';dlSpinner.style.display='none';dlErrorIc.style.display='';dlTitle.textContent='Download Failed';dlMsg.textContent=m||'Something went wrong.';dlFilename.textContent='';setTimeout(()=>dlOverlay.classList.remove('open'),2500)}
function delayThen(start,fn){var w=Math.max(0,MIN_MS-(Date.now()-start));setTimeout(fn,w)}
function triggerBlob(blob,name){var a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=name;document.body.appendChild(a);a.click();document.body.removeChild(a);setTimeout(()=>URL.revokeObjectURL(a.href),1000)}

// PDF builder
function buildRegPdf(data){
  var jsPDF=window.jspdf.jsPDF;
  var doc=new jsPDF({orientation:'landscape',unit:'mm',format:'a4'});
  var pw=doc.internal.pageSize.getWidth();
  var generated=fmtDate(new Date().toISOString());
  // Header gradient
  var steps=80,hH=28;
  for(var i=0;i<steps;i++){var r=Math.round(10+i/steps*194);doc.setFillColor(r,Math.max(0,10-i/steps*10),Math.max(0,40-i/steps*40));doc.rect(i*pw/steps,0,pw/steps+.5,hH,'F')}
  if(_whiteLogo){var lh=18,lw=lh*_logoAspect;doc.addImage(_whiteLogo,'PNG',10,5,lw,lh)}
  doc.setFont('helvetica','bold');doc.setFontSize(18);doc.setTextColor(255,255,255);doc.text('REGISTRATIONS REPORT',34,13);
  doc.setFontSize(9);doc.setTextColor(255,200,200);doc.text('IBCC Youth Week 26',34,19);
  doc.setFontSize(24);doc.setTextColor(255,255,255);doc.text(String(data.length),pw-10,14,{align:'right'});
  doc.setFontSize(8);doc.setTextColor(255,200,200);doc.text('registrations',pw-10,20,{align:'right'});
  doc.setFillColor(204,0,0);doc.rect(0,hH,pw,2,'F');
  doc.setFillColor(245,245,250);doc.rect(0,hH+2,pw,10,'F');
  doc.setFont('helvetica','normal');doc.setFontSize(8);doc.setTextColor(100,100,130);
  doc.text(data.length+' registrations',10,hH+8.5);doc.text('Generated: '+generated,pw-10,hH+8.5,{align:'right'});
  var startY=hH+16;
  doc.autoTable({
    head:[['#','ID','Name','Email','Age','Church / Corps','Role','Heard Via','Date']],
    body:data.map((r,i)=>[i+1,r.id,r.name,r.email,r.age,r.church||'—',r.role,r.heard||'—',fmtDate(r.createdAt)]),
    startY,theme:'grid',
    styles:{fontSize:8.5,cellPadding:3,textColor:[30,30,50],lineColor:[220,220,230],lineWidth:.2},
    headStyles:{fillColor:[30,30,55],textColor:[255,255,255],fontStyle:'bold',fontSize:7.5,cellPadding:3},
    alternateRowStyles:{fillColor:[248,248,252]},
    margin:{left:8,right:8},
    didDrawPage:function(d){
      if(d.pageNumber>1){for(var i=0;i<steps;i++){var r=Math.round(10+i/steps*194);doc.setFillColor(r,0,0);doc.rect(i*pw/steps,0,pw/steps+.5,hH,'F')}doc.setFillColor(204,0,0);doc.rect(0,hH,pw,2,'F')}
      var ph=doc.internal.pageSize.getHeight();doc.setFontSize(7);doc.setTextColor(150,150,170);
      doc.text('IBCC Youth Week 26 — Registrations',8,ph-5);doc.text('Page '+d.pageNumber,pw-8,ph-5,{align:'right'});
    }
  });
  return doc.output('blob');
}

function logDl(type,dataset,filename){fetch('/admin/api/log-download',{method:'POST',credentials:'same-origin',headers:{'Content-Type':'application/json','X-CSRF-Token':document.querySelector('meta[name="csrf-token"]').content},body:JSON.stringify({type:type,dataset:dataset,filename:filename})}).catch(()=>{})}

document.querySelectorAll('.pdf-download-link').forEach(link=>{
  link.addEventListener('click',e=>{
    e.preventDefault();if(link.classList.contains('disabled'))return;
    var stamp=fileStamp(),filename='yw26-registrations-'+stamp+'.pdf',start=Date.now();
    showDl(filename,'PDF');
    _logoReady.then(()=>{
      try{var blob=buildRegPdf(__registrations);delayThen(start,()=>{triggerBlob(blob,filename);showOk(filename,'PDF');logDl('PDF','registrations',filename)})}
      catch(err){delayThen(start,()=>showErr(err.message))}
    });
  });
});

document.querySelectorAll('.file-download-link').forEach(link=>{
  link.addEventListener('click',e=>{
    e.preventDefault();if(link.classList.contains('disabled'))return;
    var url=link.getAttribute('href'),isJSON=url.includes('/json'),ext=isJSON?'.json':'.csv',label=isJSON?'JSON':'CSV';
    var stamp=fileStamp(),filename=(url.includes('registrations')?'yw26-registrations-':'yw26-contacts-')+stamp+ext,start=Date.now();
    showDl(filename,label);
    fetch(url,{credentials:'same-origin'}).then(r=>{if(!r.ok)throw new Error('Server error '+r.status);return r.blob()})
      .then(blob=>delayThen(start,()=>{triggerBlob(blob,filename);showOk(filename,label)}))
      .catch(err=>delayThen(start,()=>showErr(err.message)));
  });
});
</script>
</body>
</html>
