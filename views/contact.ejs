<style>
  /* ── contact.ejs specific ── */
  @media (max-width: 480px) {
    .contact-info-card h3 { font-size: 18px; }
    .contact-info-card > p { font-size: 13px; margin-bottom: 16px; }
    .contact-info-row { gap: 12px; padding: 12px 0; }
    .ci-icon { width: 36px; height: 36px; border-radius: 8px; flex-shrink: 0; }
    .ci-icon svg { width: 16px; height: 16px; }
    .social-grid { grid-template-columns: repeat(3, 1fr); gap: 8px; margin-top: 20px !important; }
    .social-btn { padding: 12px 4px; font-size: 10px; gap: 4px; border-radius: 8px; }
    .social-btn svg { width: 18px; height: 18px; }
    .form-card h3 { font-size: 18px; }
    .form-intro { font-size: 12px; }
    div[style*="display:flex"][style*="gap:12px"] {
      flex-direction: column !important;
      gap: 10px !important;
    }
    .btn-submit, #resetBtn {
      width: 100% !important;
      justify-content: center;
    }
  }
</style>

<style>
  /* ── Shared inner-page hero ── */
  .page-hero {
    min-height: 0 !important;
    padding: calc(var(--nav-h) + 64px) 0 60px !important;
  }
  @media (max-width: 768px) {
    .page-hero { padding: calc(var(--nav-h) + 52px) 0 48px !important; }
    .page-title { line-height: .88; }
  }
  @media (max-width: 480px) {
    .page-hero { padding: calc(var(--nav-h) + 44px) 0 40px !important; }
    .page-title { font-size: clamp(52px, 15vw, 80px) !important; font-weight: 900; letter-spacing: 1px; }
    .page-hero-sub { font-size: 14px; max-width: 90vw; }
    .eyebrow { font-size: 11px; letter-spacing: 3px; margin-bottom: 16px; }
    .cta-banner div[style] { flex-direction: column !important; align-items: stretch !important; }
    .cta-banner .btn-primary,
    .cta-banner .btn-ghost { width: 100%; justify-content: center; text-align: center; }
    .section-title { line-height: 1.05; }
  }
</style>


