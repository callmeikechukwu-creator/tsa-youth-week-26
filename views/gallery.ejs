<%- include('partials/head') %>
<%- include('partials/nav') %>

<style>
  /* ── gallery.ejs specific ── */
  @media (max-width: 768px) {
    .gallery-filters {
      /* Allow horizontal scroll if too many filters */
      overflow-x: auto;
      flex-wrap: nowrap;
      padding-bottom: 4px;
      -webkit-overflow-scrolling: touch;
      /* Hide scrollbar visually */
      scrollbar-width: none;
    }
    .gallery-filters::-webkit-scrollbar { display: none; }
    .filter-btn { flex-shrink: 0; white-space: nowrap; }
  }
  @media (max-width: 480px) {
    /* Allow wrap for small but manageable filter counts */
    .gallery-filters { flex-wrap: wrap; overflow-x: visible; }
    /* Grid: 2 cols, square-ish rows */
    .gallery-grid { grid-template-columns: 1fr 1fr; grid-auto-rows: 130px; gap: 8px; }
    .g-large { grid-column: span 2; grid-row: span 1; }
    /* Placeholder icon: smaller */
    .g-placeholder-inner svg { width: 24px; height: 24px; }
    .g-placeholder-inner span { font-size: 10px; }
    .gallery-note { font-size: 12px; }
    .gallery-note code { font-size: 11px; }
  }
  @media (max-width: 360px) {
    .gallery-grid { grid-auto-rows: 110px; gap: 6px; }
    .g-large { grid-column: span 2; }
  }
</style>

<style>
  /* ── Shared inner-page mobile fixes ── */

  /* ── Shared inner-page hero ── */
  .page-hero {
    min-height: 0 !important;
    padding: calc(var(--nav-h) + 64px) 0 60px !important;
  }
  @media (max-width: 768px) {
    .page-hero { padding: calc(var(--nav-h) + 52px) 0 48px !important; }
    .page-title { line-height: .88; }
  }
  @media (max-width: 480px) {
    .page-hero { padding: calc(var(--nav-h) + 44px) 0 40px !important; }
    .page-title { font-size: clamp(52px, 15vw, 80px) !important; font-weight: 900; letter-spacing: 1px; }
    .page-hero-sub { font-size: 14px; max-width: 90vw; }
    .eyebrow { font-size: 11px; letter-spacing: 3px; margin-bottom: 16px; }
    .cta-banner div[style] { flex-direction: column !important; align-items: stretch !important; }
    .cta-banner .btn-primary,
    .cta-banner .btn-ghost { width: 100%; justify-content: center; text-align: center; }
    .section-title { line-height: 1.05; }
  }
</style>


<section class="page-hero">
  <div class="page-hero-bg gallery-bg">
    <div class="page-hero-particles">
      <div class="ph-particle"></div><div class="ph-particle"></div>
      <div class="ph-particle"></div><div class="ph-particle"></div>
      <div class="ph-particle"></div><div class="ph-particle"></div>
    </div>
  </div>
  <div class="page-hero-accent"></div>
  <div class="container">
    <div class="page-hero-content">
      <span class="eyebrow reveal">Captured Moments</span>
      <h1 class="page-title reveal rd1"><em>Gallery</em></h1>
      <p class="page-hero-sub reveal rd2">Snapshots from the Youth Retreat 2026 — three days of faith, fellowship, and greater impact.</p>
    </div>
  </div>
</section>

