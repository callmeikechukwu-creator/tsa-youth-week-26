<!-- ═══════════════ HERO ═══════════════ -->
<style>
  /* Fix: hero vertically centers on tall viewports causing huge dead space above content on mobile.
     On mobile we align to flex-start and use padding-top instead. */
  @media (max-width: 768px) {
    .hero {
      align-items: flex-start;
      min-height: 100svh;
    }
    .hero-inner {
      padding-top: calc(var(--nav-h) + 40px);
      padding-bottom: 72px;
      width: 100%;
      max-width: none;
    }
  }
  @media (max-width: 480px) {
    .hero-inner {
      padding-top: calc(var(--nav-h) + 28px);
      padding-bottom: 56px;
    }
    /* Badge: prevent wrapping on narrow screens */
    .hero-badge {
      font-size: 9px;
      letter-spacing: 1px;
      padding: 6px 12px;
      white-space: normal;
      max-width: 100%;
    }
  }
</style>
<section class="hero">
  <div class="hero-bg">
    <div class="hero-glow glow-1"></div>
    <div class="hero-glow glow-2"></div>
    <div class="hero-grid-overlay"></div>
    <div class="hero-shapes">
      <div class="hero-shape"></div>
      <div class="hero-shape"></div>
      <div class="hero-shape"></div>
      <div class="hero-shape"></div>
      <div class="hero-shape"></div>
    </div>
    <div class="hero-cross"></div>
  </div>

  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-badge reveal rd1">
        <span class="badge-pulse"></span>
        <span>Youth Retreat 2026 · IBCC</span>
      </div>
      <h1 class="hero-title reveal rd2">
        <span class="ht-line">BUILT FOR</span>
        <span class="ht-line ht-stroke">GREATER</span>
        <span class="ht-line ht-red">IMPACT</span>
      </h1>
      <p class="hero-sub reveal rd3">
        <em>"Arise, shine, for your light has come!"</em> — Isaiah 60:1<br>
        Three days of faith, skills, worship, and fellowship at the Salvation Army Ibadan Central Corps Youth Retreat 2026.
      </p>
      <div class="hero-cta reveal rd4">
        <a href="/join" class="btn-primary btn-lg" style="text-align:center;">Register Now</a>
        <a href="/activities" class="btn-ghost btn-lg" style="text-align:center;border-color:rgba(255,255,255,0.25);">View Programme</a>
      </div>
    </div>
  </div>

  <div class="hero-slash"></div>
</section>

