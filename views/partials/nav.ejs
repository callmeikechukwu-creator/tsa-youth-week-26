<body>

<!-- Loader -->
<div id="loader">
  <div class="loader-shield">
    <img src="/images/tsa-logo.png" alt="TSA Logo" class="loader-logo">
  </div>
  <div class="loader-dots">
    <span></span><span></span><span></span>
  </div>
  <p class="loader-label"><%= locals.loaderText || 'IBCC Youth Fellowship' %></p>
</div>

<!-- Navbar -->
<nav id="nav" class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-brand">
      <img src="/images/tsa-logo.png" alt="TSA Logo" class="brand-shield">
      <div class="brand-text">
        <strong>The Salvation Army</strong>
        <span>IBCC Youth Fellowship</span>
      </div>
    </a>
    <style>
      /* Always show both brand lines — shrink instead of hide */
      .brand-text span { display: block !important; }
      @media (max-width: 480px) {
        .brand-text strong { font-size: 11px; }
        .brand-text span   { font-size: 9px; letter-spacing: 0; }
        .brand-shield      { width: 36px; }
      }
      @media (max-width: 360px) {
        .brand-text strong { font-size: 10px; }
        .brand-text span   { font-size: 8px; }
        .brand-shield      { width: 32px; }
      }

      /* Drawer: register button always visible near top, not pushed to bottom */
      .drawer {
        overflow-y: auto;
      }
      .drawer-register-btn {
        margin-top: 16px !important;
        flex-shrink: 0;
      }
    </style>
    <div class="nav-links">
      <a href="/" class="nav-link <%= page === 'home' ? 'active' : '' %>">Home</a>
      <a href="/about" class="nav-link <%= page === 'about' ? 'active' : '' %>">About</a>
      <a href="/activities" class="nav-link <%= page === 'activities' ? 'active' : '' %>">Activities</a>
      <a href="/gallery" class="nav-link <%= page === 'gallery' ? 'active' : '' %>">Gallery</a>
      <a href="/speakers" class="nav-link <%= page === 'speakers' ? 'active' : '' %>">Speakers</a>
      <a href="/join" class="nav-link <%= page === 'join' ? 'active' : '' %>">Join</a>
      <a href="/contact" class="nav-link <%= page === 'contact' ? 'active' : '' %>">Contact</a>
    </div>
    <div class="nav-cta">
      <a href="/join" class="btn-primary">Register Now</a>
      <button class="hamburger" id="hamburger" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</nav>

<!-- Drawer Overlay -->
<div id="drawerOverlay" class="drawer-overlay"></div>

<!-- Drawer -->
<div id="drawer" class="drawer">
  <div class="drawer-header">
    <span>Navigation</span>
    <button id="drawerClose" aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
        <path d="M4.646 4.646a.5.5 0 0 1 .708 0L8 7.293l2.646-2.647a.5.5 0 0 1 .708.708L8.707 8l2.647 2.646a.5.5 0 0 1-.708.708L8 8.707l-2.646 2.647a.5.5 0 0 1-.708-.708L7.293 8 4.646 5.354a.5.5 0 0 1 0-.708"/>
      </svg>
    </button>
  </div>
  <a href="/" class="<%= page === 'home' ? 'active' : '' %>">Home</a>
  <a href="/about" class="<%= page === 'about' ? 'active' : '' %>">About</a>
  <a href="/activities" class="<%= page === 'activities' ? 'active' : '' %>">Activities</a>
  <a href="/gallery" class="<%= page === 'gallery' ? 'active' : '' %>">Gallery</a>
  <a href="/speakers" class="<%= page === 'speakers' ? 'active' : '' %>">Speakers</a>
  <a href="/join" class="<%= page === 'join' ? 'active' : '' %>">Join</a>
  <a href="/contact" class="<%= page === 'contact' ? 'active' : '' %>">Contact</a>
  <a href="/join" class="drawer-register-btn">Register Now</a>
</div>
