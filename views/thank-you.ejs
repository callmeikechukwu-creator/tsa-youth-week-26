<%- include('partials/head') %>
<%- include('partials/nav') %>

<style>
  /* ── thank-you.ejs specific ── */
  @media (max-width: 480px) {
    .ty-wrap { padding: 0; }
    .ty-card { padding: 20px 16px; }
    .ty-card h2 { font-size: clamp(22px, 6vw, 32px); margin-bottom: 10px; }
    .ty-sub { font-size: 13px; margin-bottom: 20px; }
    .ty-icon { width: 56px; height: 56px; margin-bottom: 16px; }
    .ty-icon svg { width: 28px; height: 28px; }
    /* Steps: tighter */
    .ty-steps { margin-bottom: 24px; }
    .ty-step { padding: 12px 14px; gap: 12px; }
    .ty-step-num { width: 24px; height: 24px; font-size: 12px; }
    .ty-step strong { font-size: 13px; }
    .ty-step span   { font-size: 12px; }
    /* Action buttons: full width stack */
    .ty-actions { flex-direction: column; gap: 10px; }
    .ty-actions a { width: 100%; justify-content: center; text-align: center; }
    /* Info strip: column on mobile */
    .ty-info { flex-direction: column; align-items: flex-start; gap: 10px; padding: 16px; }
    .ty-info-item { font-size: 12px; }
  }
</style>

<style>
  /* ── Shared inner-page mobile fixes ── */

  /* 1. Remove min-height from page-hero — tall phones get huge dead space otherwise */
  .page-hero {
    min-height: 0 !important;
    padding: calc(var(--nav-h) + 56px) 0 52px !important;
  }
  @media (max-width: 768px) {
    .page-hero { padding: calc(var(--nav-h) + 44px) 0 40px !important; }
    .page-title { line-height: .9; }
  }
  @media (max-width: 480px) {
    .page-hero { padding: calc(var(--nav-h) + 32px) 0 32px !important; }
    .page-title { font-size: clamp(36px, 11vw, 60px); }
    .page-hero-sub { font-size: 13px; }
    /* CTA banner buttons go full-width and stack */
    .cta-banner div[style] { flex-direction: column !important; align-items: stretch !important; }
    .cta-banner .btn-primary,
    .cta-banner .btn-ghost { width: 100%; justify-content: center; text-align: center; }
    /* Section titles breathe more */
    .section-title { line-height: 1.05; }
  }
</style>


<section class="page-hero">
  <div class="page-hero-bg <%= type === 'registration' ? 'join-bg' : 'contact-bg' %>">
    <div class="page-hero-particles">
      <div class="ph-particle"></div><div class="ph-particle"></div>
      <div class="ph-particle"></div><div class="ph-particle"></div>
    </div>
  </div>
  <div class="page-hero-accent"></div>
  <div class="container">
    <div class="page-hero-content">
      <span class="eyebrow reveal"><%= type === 'registration' ? 'Registration Confirmed' : 'Message Received' %></span>
      <h1 class="page-title reveal rd1"><em><%= type === 'registration' ? 'You\'re In!' : 'Thank You' %></em></h1>
    </div>
  </div>
</section>

<section class="section-pad">
  <div class="container">
    <div class="ty-wrap">

      <div class="ty-card reveal">

        <!-- Icon -->
        <div class="ty-icon">
          <% if (type === 'registration') { %>
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" viewBox="0 0 16 16">
            <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
            <path d="m10.97 4.97-.02.022-3.473 4.425-2.093-2.094a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-1.071-1.05"/>
          </svg>
          <% } else { %>
          <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" viewBox="0 0 16 16">
            <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1zm13 2.383-4.708 2.825L15 11.105zm-.034 6.876-5.64-3.471L8 9.583l-1.326-.795-5.64 3.47A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.741M1 11.105l4.708-2.897L1 5.383z"/>
          </svg>
          <% } %>
        </div>

        <!-- Heading -->
        <% if (name) { %>
          <h2>Thank you, <%= name %>!</h2>
        <% } else { %>
          <h2>Thank you!</h2>
        <% } %>

        <% if (type === 'registration') { %>
          <p class="ty-sub">Your registration has been received. We'll be in touch with updates about Youth Week 27 and future events. We look forward to seeing you!</p>

          <div class="ty-steps">
            <div class="ty-step">
              <div class="ty-step-num">1</div>
              <div>
                <strong>Registration logged</strong>
                <span>Your details have been saved in our system.</span>
              </div>
            </div>
            <div class="ty-step">
              <div class="ty-step-num">2</div>
              <div>
                <strong>Stay connected</strong>
                <span>Follow us on social media and WhatsApp for updates.</span>
              </div>
            </div>
            <div class="ty-step">
              <div class="ty-step-num">3</div>
              <div>
                <strong>Show up!</strong>
                <span>Join us at The Salvation Army IBCC, Ibadan. Entry is free.</span>
              </div>
            </div>
          </div>

        <% } else { %>
          <p class="ty-sub">We've received your message and will get back to you as soon as possible. Our team typically responds within 24–48 hours.</p>

          <div class="ty-steps">
            <div class="ty-step">
              <div class="ty-step-num">1</div>
              <div>
                <strong>Message received</strong>
                <span>Your message has been delivered to our team.</span>
              </div>
            </div>
            <div class="ty-step">
              <div class="ty-step-num">2</div>
              <div>
                <strong>We'll be in touch</strong>
                <span>Expect a reply within 24–48 hours via email.</span>
              </div>
            </div>
            <div class="ty-step">
              <div class="ty-step-num">3</div>
              <div>
                <strong>Need it faster?</strong>
                <span>Reach us directly on WhatsApp: <a href="https://wa.me/2348078800552" target="_blank" rel="noopener">+234 807 880 0552</a></span>
              </div>
            </div>
          </div>
        <% } %>

        <!-- Actions -->
        <div class="ty-actions">
          <a href="/" class="btn-primary">Back to Home</a>
          <% if (type === 'registration') { %>
            <a href="/activities" class="btn-ghost">View Programme</a>
          <% } else { %>
            <a href="https://wa.me/2348078800552" target="_blank" rel="noopener" class="btn-ghost">WhatsApp Us</a>
          <% } %>
        </div>

      </div>

      <!-- Info strip -->
      <div class="ty-info reveal rd2">
        <div class="ty-info-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M8 16s6-5.686 6-10A6 6 0 0 0 2 6c0 4.314 6 10 6 10m0-7a3 3 0 1 1 0-6 3 3 0 0 1 0 6"/></svg>
          <span>The Salvation Army IBCC, Ibadan</span>
        </div>
        <div class="ty-info-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M7 14s-1 0-1-1 1-4 5-4 5 3 5 4-1 1-1 1zm4-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6m-5.784 6A2.24 2.24 0 0 1 5 13c0-1.355.68-2.75 1.936-3.72A6.3 6.3 0 0 0 5 9c-4 0-5 3-5 4s1 1 1 1zM4.5 8a2.5 2.5 0 1 0 0-5 2.5 2.5 0 0 0 0 5"/></svg>
          <span>Ages 13–35 Welcome</span>
        </div>
        <div class="ty-info-item">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M1 3a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1H1zm7 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4"/><path d="M0 5a1 1 0 0 1 1-1h14a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H1a1 1 0 0 1-1-1zm3 0a2 2 0 0 1-2 2v4a2 2 0 0 1 2 2h10a2 2 0 0 1 2-2V7a2 2 0 0 1-2-2z"/></svg>
          <span>Free Registration · No Cost</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
.ty-wrap {
  max-width: 700px;
  margin: 0 auto;
}

.ty-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
  padding: clamp(32px, 5vw, 56px);
  text-align: center;
  margin-bottom: 24px;
  position: relative;
  overflow: hidden;
}

.ty-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--red), var(--blue));
}

.ty-icon {
  width: 72px; height: 72px;
  background: rgba(0, 200, 100, 0.12);
  border: 1px solid rgba(0, 200, 100, 0.25);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
  color: #00c864;
}

.ty-card h2 {
  font-family: var(--font-display);
  font-size: clamp(28px, 4vw, 42px);
  letter-spacing: 1px;
  margin-bottom: 14px;
}

.ty-sub {
  font-size: 15px;
  color: var(--text-muted);
  line-height: 1.75;
  max-width: 480px;
  margin: 0 auto 32px;
}

.ty-steps {
  display: flex;
  flex-direction: column;
  gap: 0;
  text-align: left;
  margin-bottom: 36px;
  border: 1px solid var(--border);
  border-radius: var(--r);
  overflow: hidden;
}

.ty-step {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  padding: 16px 20px;
  border-bottom: 1px solid var(--border);
  font-size: 14px;
}

.ty-step:last-child { border-bottom: none; }

.ty-step-num {
  width: 28px; height: 28px;
  background: var(--red);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
  flex-shrink: 0;
  margin-top: 1px;
}

.ty-step div { display: flex; flex-direction: column; gap: 2px; }
.ty-step strong { font-weight: 700; font-size: 14px; }
.ty-step span   { font-size: 13px; color: var(--text-muted); }
.ty-step span a { color: var(--red); text-decoration: underline; }

.ty-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
  flex-wrap: wrap;
}

.ty-info {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  justify-content: center;
  padding: 20px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--r-lg);
}

.ty-info-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--text-muted);
}
.ty-info-item svg { fill: var(--red); flex-shrink: 0; }

@media (max-width: 480px) {
  /* already handled in page-specific block above */
  .ty-card { padding: 20px 16px; }
}
</style>

<%- include('partials/footer') %>
